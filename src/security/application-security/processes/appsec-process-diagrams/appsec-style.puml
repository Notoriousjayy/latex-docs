' appsec-style.puml
' Common styling for AppSec process diagrams.
' Design goals: clear purpose, consistent layout, minimal palette, and high legibility.
'
' NOTE: 'left to right direction' was REMOVED — it is incompatible with the
' modern activity-diagram syntax (start/:foo;/stop) used by every diagram that
' includes this file. With it present, PlantUML falls back to
' "Assumed diagram type: class" and reports a syntax error at the first 'start'.

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 10

skinparam defaultFontName Arial
skinparam defaultFontSize 12

skinparam ArrowColor #444444
skinparam ActivityBorderColor #444444
skinparam ActivityBackgroundColor #F7F7F7
skinparam ActivityDiamondBorderColor #444444
skinparam ActivityDiamondBackgroundColor #F7F7F7
skinparam ActivityBarColor #444444

skinparam NoteBackgroundColor #FFF8D6
skinparam NoteBorderColor #C7A700

' Highlight key gates with a third, subtle color (blue).
' Stereotype variants must be top-level skinparams; PlantUML rejects them
' inside a 'skinparam activity { ... }' block.
skinparam ActivityBackgroundColor<<gate>> #E9F5FF
skinparam ActivityBorderColor<<gate>> #2F6FAB
skinparam ActivityFontColor<<gate>> #123A5A
skinparam ActivityDiamondBackgroundColor<<gate>> #E9F5FF
skinparam ActivityDiamondBorderColor<<gate>> #2F6FAB
skinparam ActivityDiamondFontColor<<gate>> #123A5A

' Keep partitions visually clean.
skinparam PartitionBorderColor #777777
skinparam PartitionFontColor #111111

skinparam TitleFontSize 16
skinparam TitleFontStyle bold

' Optional: legend styling
skinparam LegendBackgroundColor #FFFFFF
skinparam LegendBorderColor #777777



