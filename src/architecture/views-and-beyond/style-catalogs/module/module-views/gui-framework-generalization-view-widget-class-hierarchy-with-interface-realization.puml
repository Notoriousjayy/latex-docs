@startuml

title <b>GUI Framework — Generalization View</b>\nWidget class hierarchy with interface realization

!include ../../../../../../tooling/styles/plantuml/structural/class-diagram-style.iuml

abstract class "Widget" as W {
  + draw()
  + resize()
  + handleEvent()
}

abstract class "Container" as C {
  + addChild()
  + removeChild()
  + layout()
}

class "Button" as B {
  + onClick()
  + setLabel()
}

class "Label" as L {
  + setText()
  + setFont()
}

class "TextField" as TF {
  + getValue()
  + setValue()
}

class "Panel" as P {
  + setTitle()
  + setBorder()
}

class "Window" as WN {
  + open()
  + close()
  + setTitle()
}

interface "EventListener" as EL {
  + onEvent()
}

interface "Observable" as OB {
  + addObserver()
  + notifyObservers()
}

W <|-- C
W <|-- B
W <|-- L
W <|-- TF
C <|-- P
C <|-- WN

EL <|.. B
EL <|.. TF
OB <|.. W
@enduml
