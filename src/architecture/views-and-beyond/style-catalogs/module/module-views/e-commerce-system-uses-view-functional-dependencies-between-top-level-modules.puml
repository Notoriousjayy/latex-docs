@startuml

title <b>E-Commerce System — Uses View</b>\nFunctional dependencies between top-level modules

!include ../../../../../../tooling/styles/plantuml/structural/component-diagram-style.iuml

rectangle "Order\nManagement" as OM <<core>>

rectangle "Catalog\nManagement" as CM <<support>>
rectangle "Customer\nManagement" as CU <<support>>
rectangle "Payment\nProcessing" as PP <<support>>
rectangle "Inventory\nManagement" as IM <<support>>
rectangle "Shipping\nIntegration" as SI <<support>>

OM -[#E11D48,bold]down-> CM : " product info "
OM -[#E11D48,bold]down-> CU : " customer data "
OM -[#E11D48,bold]down-> PP : " payments "
OM -[#E11D48,bold]down-> IM : " stock updates "
OM -[#E11D48,bold]down-> SI : " delivery "

note right of OM
  Central module with highest
  fan-out dependency count.
  Changes here have widest impact.
end note
@enduml
