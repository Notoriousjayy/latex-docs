@startuml

title <b>E-Commerce System — Layered View</b>\nDependencies flow strictly downward

!include ../../../../../../tooling/styles/plantuml/structural/component-diagram-style.iuml

rectangle "  **Presentation Layer**  \n  Web UI  ·  Mobile UI  " as PL <<L1>>
rectangle "  **Application Layer**  \n  Use-case coordination  " as AL <<L2>>
rectangle "  **Domain Layer**  \n  Business logic  ·  Entities  " as DL <<L3>>
rectangle "  **Infrastructure Layer**  \n  Persistence  ·  Messaging  ·  External services  " as IL <<L4>>

PL -[#4B5563,bold]down-> AL : " allowed-to-use "
AL -[#4B5563,bold]down-> DL : " allowed-to-use "
DL -[#4B5563,bold]down-> IL : " allowed-to-use "

note right of PL
  <b>Constraint:</b>
  Each layer may only
  depend on layers
  directly below it.
end note
@enduml

