@startuml

skinparam padding 4

!include ../../../../../../tooling/styles/plantuml/structural/component-diagram-style.iuml

title <b>Module Property Categories</b>\nComprehensive documentation captures six property groups

rectangle "**Module**" as M <<module>>

rectangle "**Identity**" as ID <<cat>>
rectangle "**Responsibility**" as RS <<cat>>
rectangle "**Interface**" as IF <<cat>>
rectangle "**Quality**" as QL <<cat>>
rectangle "**Implementation**" as IM <<cat>>
rectangle "**Organizational**" as OR <<cat>>

rectangle "Name\nQualified name\nVersion" as ID_P <<prop>>
rectangle "Purpose\nResponsibilities\nScope · Constraints" as RS_P <<prop>>
rectangle "Provided interface\nRequired interface\nContracts" as IF_P <<prop>>
rectangle "Cohesion\nCoupling\nStability · Abstractness" as QL_P <<prop>>
rectangle "Technology\nSize · Complexity\nLocation" as IM_P <<prop>>
rectangle "Owner · Team\nStatus" as OR_P <<prop>>

M -down-> ID
M -down-> RS
M -down-> IF
M -down-> QL
M -down-> IM
M -down-> OR

ID -down-> ID_P
RS -down-> RS_P
IF -down-> IF_P
QL -down-> QL_P
IM -down-> IM_P
OR -down-> OR_P
@enduml
