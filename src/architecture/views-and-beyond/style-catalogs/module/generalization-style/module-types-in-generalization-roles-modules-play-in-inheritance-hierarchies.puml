@startuml

title **Module Types in Generalization**\nRoles modules play in inheritance hierarchies

!include ../../../../../../tooling/styles/plantuml/structural/class-diagram-style.iuml

package "Abstract Modules" #FDEBD0 {
  abstract class "AbstractModule" as absmod #FFF3E0 {
    + concreteMethod()
    {abstract} + abstractMethod()
  }
}

package "Interface Modules" #E8DAEF {
  interface "IContract" as iface #F3E5F5 {
    + operationA()
    + operationB()
  }
}

package "Concrete Modules" #D5E8D4 {
  class "ConcreteModule" as conmod #E8F5E9 {
    + concreteMethod()
    + abstractMethod()
    + ownMethod()
  }
}

package "Mixin / Trait Modules" #D6EAF8 {
  class "<<mixin>> Loggable" as mixin #E3F2FD {
    + log(message)
  }
  class "<<trait>> Serializable" as trait #E3F2FD {
    + serialize()
    + deserialize()
  }
}

absmod <|-- conmod
iface <|.. conmod

note bottom of absmod
  Cannot be instantiated.
  Partial implementation;
  children must complete it.
end note

note bottom of iface
  Pure contract: no implementation.
  Multiple unrelated modules
  can implement the same interface.
end note

note bottom of conmod
  Fully implemented; instantiable.
  May inherit from abstract module
  or implement interfaces.
end note

note bottom of mixin
  Reusable functionality
  composed into classes.
  Traits add conflict resolution.
end note

@enduml

