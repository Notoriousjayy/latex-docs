@startuml
skinparam nodesep 40
!include ../../../../../../tooling/styles/plantuml/structural/class-diagram-style.iuml

skinparam ranksep 35

title **Common Generalization Patterns**\nDesign patterns that rely on inheritance hierarchies

package "Template Method" #FDEBD0 {
  abstract class "DataParser" as dp #FFF3E0 {
    + parse() <<final>>
    {abstract} # readData()
    {abstract} # processData()
    {abstract} # writeResult()
  }
  class "CSVParser" as csv #E8F4FD {
    # readData()
    # processData()
    # writeResult()
  }
  class "XMLParser" as xml #E8F4FD {
    # readData()
    # processData()
    # writeResult()
  }
  dp <|-- csv
  dp <|-- xml
}

package "Strategy" #D6EAF8 {
  interface "SortStrategy" as ss #E3F2FD {
    + sort(data)
  }
  class "QuickSort" as qs #E8F4FD {
    + sort(data)
  }
  class "MergeSort" as ms #E8F4FD {
    + sort(data)
  }
  class "Context" as ctx #F0F0F0 {
    - strategy : SortStrategy
    + execute()
  }
  ss <|.. qs
  ss <|.. ms
  ctx --> ss : uses
}

package "Abstract Factory" #E8DAEF {
  interface "UIFactory" as uif #F3E5F5 {
    + createButton()
    + createTextField()
  }
  class "DarkThemeFactory" as dtf #E8F4FD {
    + createButton()
    + createTextField()
  }
  class "LightThemeFactory" as ltf #E8F4FD {
    + createButton()
    + createTextField()
  }
  uif <|.. dtf
  uif <|.. ltf
}

@enduml

