@startuml

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

skinparam cloud {
    BackgroundColor #FFF3E0
    BorderColor #F57C00
}

title Client-Server Basic Architecture

rectangle "Client Zone" {
    component "Client A" as CA
    component "Client B" as CB
    component "Client C" as CC
}

cloud "Request/Reply\nConnector" as CONN

rectangle "Server Zone" #E8F5E9 {
    component "Server" as S #E8F5E9
}

CA --> CONN : request
CB --> CONN : request
CC --> CONN : request
CONN --> S : forward

S --> CONN : reply
CONN ..> CA
CONN ..> CB
CONN ..> CC

note bottom of S
  Server waits for requests,
  processes them, and
  returns results
end note

note top of CA
  Clients initiate
  interactions
end note

legend right
  |= Symbol |= Meaning |
  | <#E3F2FD> | Client |
  | <#E8F5E9> | Server |
  | <#FFF3E0> | Connector |
endlegend
@enduml
