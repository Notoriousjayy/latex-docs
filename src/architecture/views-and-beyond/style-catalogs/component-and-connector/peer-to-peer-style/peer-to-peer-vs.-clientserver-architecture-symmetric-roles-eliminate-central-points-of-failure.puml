@startuml 01-p2p-vs-client-server

!include ../../../../../../tooling/styles/plantuml/structural/package-diagram-style.iuml

skinparam padding 6

title <b>Peer-to-Peer vs. Client–Server Architecture</b>\nSymmetric roles eliminate central points of failure

package "Client–Server Model" as CS {
  rectangle "Server" as srv <<server>>
  rectangle "Client A" as ca <<client>>
  rectangle "Client B" as cb <<client>>
  rectangle "Client C" as cc <<client>>

  ca -[#3B82F6]-> srv : request
  srv -[#3B82F6]-> ca : response
  cb -[#3B82F6]-> srv : request
  srv -[#3B82F6]-> cb : response
  cc -[#3B82F6]-> srv : request
  srv -[#3B82F6]-> cc : response
}

package "Peer-to-Peer Model" as P2P {
  rectangle "Peer 1" as p1 <<peer>>
  rectangle "Peer 2" as p2 <<peer>>
  rectangle "Peer 3" as p3 <<peer>>
  rectangle "Peer 4" as p4 <<peer>>

  p1 <-[#10B981]-> p2
  p2 <-[#10B981]-> p3
  p3 <-[#10B981]-> p4
  p4 <-[#10B981]-> p1
  p1 <-[#10B981]-> p3
  p2 <-[#10B981]-> p4
}

legend right
  |<#3B82F6> <color:#FFFFFF>  Server  </color>| Central service provider |
  |<#BFDBFE>   Client  | Service consumer only |
  |<#10B981> <color:#FFFFFF>  Peer  </color>| Both provider and consumer |
end legend
@enduml

