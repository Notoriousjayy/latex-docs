@startuml 02-peer-types

!include ../../../../../../tooling/styles/plantuml/structural/component-diagram-style.iuml

skinparam padding 4

title <b>Peer Component Types</b>\nClassification by capability and role in the network

rectangle "Full Peer" as fp <<full>> {
}
rectangle "Light Peer" as lp <<light>> {
}
rectangle "Super Peer" as sp <<super>> {
}
rectangle "Bootstrap Peer" as bp <<bootstrap>> {
}
rectangle "Relay Peer" as rp <<relay>> {
}

note right of fp
  Complete state & all services
  Routes for others
  Highest resource usage
end note

note right of lp
  Partial state only
  Depends on full peers
  Conserves resources
end note

note right of sp
  Indexes & coordinates
  Serves cluster of peers
  Partial hierarchy
end note

note right of bp
  Well-known entry point
  Provides initial peer list
  Not needed after join
end note

note right of rp
  Forwards traffic
  Assists NAT-blocked peers
  Enables connectivity
end note

fp -[hidden]-> lp
lp -[hidden]-> sp
sp -[hidden]-> bp
bp -[hidden]-> rp

legend right
  |<#10B981> <color:#FFFFFF>  Full  </color>| Full network participation |
  |<#6EE7B7>   Light  | Reduced capabilities |
  |<#3B82F6> <color:#FFFFFF>  Super  </color>| Enhanced responsibilities |
  |<#F59E0B> <color:#FFFFFF>  Bootstrap  </color>| Network entry point |
  |<#8B5CF6> <color:#FFFFFF>  Relay  </color>| Connectivity assistance |
end legend
@enduml

