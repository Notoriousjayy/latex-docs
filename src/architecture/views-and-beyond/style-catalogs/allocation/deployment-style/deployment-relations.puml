@startuml

title Deployment Relations

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

rectangle "Allocated-To Relation" {
    artifact "Web Service" as ws
    node "App Server 1" as as1
    
    ws -down-> as1 : <<allocated-to>>\nstatic binding\ndedicated
}

rectangle "Migration Relations" {
    node "Node A" as nodeA {
        artifact "Service\n(original)" as origSvc
    }
    
    node "Node B" as nodeB {
        artifact "Service\n(migrated)" as migratedSvc
    }
    
    node "Node C" as nodeC {
        artifact "Service\n(replica)" as replicaSvc
    }
    
    origSvc -right-> migratedSvc : <<migrates-to>>\nfailover
    origSvc -down-> replicaSvc : <<copy-migrates-to>>\nscale-out
}

rectangle "Communicates-With\n(Cross-Boundary)" {
    node "Zone A" as zoneA {
        artifact "Frontend" as fe
    }
    
    node "Zone B" as zoneB {
        artifact "Backend" as be
    }
    
    fe -right-> be : <<communicates-with>>\nHTTPS:443
}

note bottom
  Relations define how software maps to hardware
  and how allocations may change over time
end note

@enduml

