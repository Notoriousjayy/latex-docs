@startuml

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

skinparam cloud {
    BackgroundColor #F5F5F5
    BorderColor #757575
}

title Multi-Region Deployment Pattern

rectangle "Global DNS / Traffic Router" as dns

cloud "Region: US-East" as usEast {
    node "Compute Cluster" as usCompute {
        artifact "App\nInstances" as usApp
    }
    database "Regional DB" as usDB
    usApp --> usDB
}

cloud "Region: EU-West" as euWest {
    node "Compute Cluster" as euCompute {
        artifact "App\nInstances" as euApp
    }
    database "Regional DB" as euDB
    euApp --> euDB
}

cloud "Region: APAC" as apac {
    node "Compute Cluster" as apacCompute {
        artifact "App\nInstances" as apacApp
    }
    database "Regional DB" as apacDB
    apacApp --> apacDB
}

actor "US Users" as usUsers
actor "EU Users" as euUsers
actor "APAC Users" as apacUsers

usUsers --> dns
euUsers --> dns
apacUsers --> dns

dns --> usApp : latency-based\nrouting
dns --> euApp
dns --> apacApp

usDB <--> euDB : cross-region\nreplication
euDB <--> apacDB

note bottom
  Considerations: Data replication strategy (sync vs async),
  traffic routing (geographic, latency-based), cross-region data transfer costs
end note

@enduml
