@startuml

title Deployment Style: Software to Hardware Mapping

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

rectangle "Software Architecture\n(C&C View)" as sw {
    component "Service A" as svcA
    component "Service B" as svcB
    component "Database\nConnector" as dbConn
}

rectangle "Deployment Architecture\n(Allocation View)" as deploy {
    node "Application Server" as appServer {
        artifact "Service A\nInstance" as svcADeploy
        artifact "Service B\nInstance" as svcBDeploy
    }
    
    node "Database Server" as dbServer {
        artifact "Database\nEngine" as dbDeploy
    }
}

svcA -[dashed]-> svcADeploy : <<allocated-to>>
svcB -[dashed]-> svcBDeploy : <<allocated-to>>
dbConn -[dashed]-> dbDeploy : <<allocated-to>>

svcADeploy --> svcBDeploy : local call
svcBDeploy --> dbDeploy : TCP/IP

note bottom of deploy
  The deployment style maps software elements
  to environmental elements (hardware/VMs/containers)
end note

@enduml
