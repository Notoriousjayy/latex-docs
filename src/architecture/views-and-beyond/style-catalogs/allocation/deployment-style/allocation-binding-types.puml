@startuml

title Allocation Binding Types

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

rectangle "Static Binding" as static {
    artifact "Service A" as svcA_static
    node "Server 1" as srv1_static
    svcA_static -down-> srv1_static : fixed at\ndeployment
}

note right of static
  Assignment does not
  change during execution
end note

rectangle "Dynamic Binding" as dynamic {
    artifact "Service B" as svcB_dyn
    node "Server 2" as srv2_dyn
    node "Server 3" as srv3_dyn
    svcB_dyn -down-> srv2_dyn : initial
    svcB_dyn .[#C62828,dashed].> srv3_dyn : migrates on\nfailure/load
}

note right of dynamic
  Assignment may change
  based on conditions
end note

rectangle "Lazy Binding" as lazy {
    artifact "Function C" as func_lazy
    node "Pool Node A" as pool1
    node "Pool Node B" as pool2
    func_lazy .[#2E7D32,dashed].> pool1 : assigned at\nfirst invocation
    func_lazy .[#2E7D32,dashed].> pool2
}

note right of lazy
  Assignment determined
  at access time
end note

@enduml

