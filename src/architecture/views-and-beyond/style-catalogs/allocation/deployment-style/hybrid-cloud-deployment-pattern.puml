@startuml

skinparam cloud {
!include ../../../../../../tooling/styles/plantuml/interaction/sequence-diagram-style.iuml

    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    FontColor #1B5E20
}

title Hybrid Cloud Deployment Pattern

rectangle "On-Premises Data Center" as onprem {
    node "Legacy Server" as legacy {
        artifact "ERP System" as erp
    }
    node "Database Server" as dbServer {
        database "Regulated\nData Store" as regulatedDB
    }
    erp --> regulatedDB
}

cloud "Public Cloud" as publicCloud {
    node "Web Tier" as webTier {
        artifact "Modern\nFrontend" as frontend
    }
    node "API Tier" as apiTier {
        artifact "API\nGateway" as api
    }
    node "Burst Capacity" as burst {
        artifact "Compute\nWorkloads" as compute
    }
}

rectangle "Secure Connection\n(VPN / Direct Connect)" as vpn

actor "External\nUsers" as extUsers
actor "Internal\nUsers" as intUsers

extUsers --> frontend
intUsers --> erp

frontend --> api
api --> vpn
vpn --> erp : sync
api --> compute
compute --> vpn
vpn --> regulatedDB : query

note as useCases
  Use cases:
  Legacy integration
  Data residency compliance
  Burst capacity
  Gradual cloud migration
end note

@enduml

