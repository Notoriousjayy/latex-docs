@startuml

title Single-Node Deployment Pattern

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

node "Single Server" as server {
    artifact "Web Server" as web
    artifact "Application" as app
    artifact "Database" as db
    
    web -down-> app : local
    app -down-> db : local
}

actor "Users" as users
users -right-> web : HTTP

rectangle "Limitations" as limits {
}

note right of limits
  No fault tolerance
  Node failure = complete outage
  Limited scalability
  Resource contention
end note

note bottom of server
  Appropriate for:
  Development environments
  Small-scale applications
  Cost-constrained scenarios
end note

@enduml
