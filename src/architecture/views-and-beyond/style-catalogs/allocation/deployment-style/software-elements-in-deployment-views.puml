@startuml

title Software Elements in Deployment Views

!include ../../../../../../tooling/styles/plantuml/structural/package-diagram-style.iuml

package "Software Element Types" {
    
    rectangle "Executables &\nProcesses\n\nCompiled binaries,\ninterpreted scripts,\nOS processes" as exec
    
    rectangle "Services\n\nLong-running processes\nwith network endpoints" as svc
    
    rectangle "Containers\n\nPackaged units with\ncode, runtime, libs" as container
    
    rectangle "Serverless\nFunctions\n\nEvent-driven code\nunits" as func
    
    rectangle "Middleware\n\nApp servers, brokers,\nAPI gateways" as middleware
    
    rectangle "Data Stores\n\nDatabases, caches,\nfile systems" as data
    
    rectangle "Batch Jobs\n\nScheduled/triggered\nperiodic processes" as batch
}

note bottom
  Each software element requires allocation to 
  environmental elements with compatible capabilities
end note

@enduml

