@startuml 05-team-topologies
!include ../../../../../../tooling/styles/plantuml/structural/component-diagram-style.iuml

skinparam padding 10
skinparam nodesep 35
skinparam ranksep 30

title <b>Team Topologies</b>\nFour Fundamental Team Types

rectangle "<b>Stream-Aligned Teams</b>\nDeliver value to customers" as stream <<stream>> {
    rectangle "Payments Team" as pay <<stream>>
    rectangle "Catalog Team" as cat <<stream>>
}

rectangle "<b>Platform Teams</b>\nProvide internal services" as platform <<platform>> {
    rectangle "Infrastructure" as infra <<platform>>
    rectangle "Developer Tools" as devtools <<platform>>
}

rectangle "<b>Enabling Teams</b>\nHelp teams overcome obstacles" as enabling <<enabling>> {
    rectangle "Security Guild" as sec <<enabling>>
}

rectangle "<b>Complicated Subsystem Teams</b>\nDeep specialist knowledge" as subsys <<subsys>> {
    rectangle "ML Engine Team" as ml <<subsys>>
}

platform -[#1565C0,dashed]u-> stream : X-as-a-Service
enabling -[#FFA000,dotted]-> stream : Facilitating
subsys -[#7B1FA2,dashed]-> stream : Collaboration

legend bottom
  |= Team Type |= Focus |
  | Stream-Aligned | Business flow, customer value |
  | Platform | Self-service internal products |
  | Enabling | Coaching, capability building |
  | Complicated Subsystem | Deep specialist expertise |
endlegend

@enduml

