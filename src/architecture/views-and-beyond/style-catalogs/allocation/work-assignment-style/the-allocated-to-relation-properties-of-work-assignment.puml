@startuml 10-allocated-to-properties
!include ../../../../../../tooling/styles/plantuml/structural/package-diagram-style.iuml

skinparam padding 10
skinparam nodesep 30

title <b>The Allocated-To Relation</b>\nProperties of Work Assignment

rectangle "Software\nElement" as sw <<sw>>
rectangle "Organizational\nElement" as org <<org>>

sw -[#1565C0,bold,thickness=3]-> org : <b>allocated-to</b>

package "Responsibility Type" as resp <<prop>> {
    rectangle "Development" as dev #C8E6C9
    rectangle "Maintenance" as maint #C8E6C9
    rectangle "Ownership" as own #C8E6C9
    rectangle "Review" as rev #C8E6C9
    rectangle "Support" as supp #C8E6C9
}

package "Exclusivity" as excl <<prop>> {
    rectangle "Exclusive" as exclusive #FFE0B2
    rectangle "Shared" as shared #FFE0B2
    rectangle "Primary/Secondary" as primsec #FFE0B2
}

package "Duration" as dur <<prop>> {
    rectangle "Permanent" as perm #E1BEE7
    rectangle "Project-based" as proj #E1BEE7
    rectangle "Temporary" as temp #E1BEE7
    rectangle "Rotational" as rot #E1BEE7
}

package "Authority Level" as auth <<prop>> {
    rectangle "Full Authority" as full #BBDEFB
    rectangle "Consultative" as consult #BBDEFB
    rectangle "Escalation Required" as escal #BBDEFB
}

note bottom
  The allocated-to relation answers:
  <b>"Who is responsible for this module?"</b>
end note

@enduml
