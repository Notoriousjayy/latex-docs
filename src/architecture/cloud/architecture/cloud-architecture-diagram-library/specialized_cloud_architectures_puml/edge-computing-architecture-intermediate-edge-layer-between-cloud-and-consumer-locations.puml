@startuml edge_computing
!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title Edge Computing Architecture\nIntermediate edge layer between cloud and consumer locations

skinparam cloud {
  BackgroundColor #F4ECF7
  BorderColor #6C3483
}

cloud "Cloud\n(heavier processing)" as cld

node "Edge A" as ea
node "Edge B" as eb
node "Edge C" as ec
node "Edge D" as ed
node "Edge E" as ee

component "Office\nLocation A" as la
component "Office\nLocation B" as lb
component "Office\nLocation C" as lc
component "Office\nLocation D" as ld
component "IoT\nDeployment A" as iotA
component "Office\nLocation E" as le
component "IoT\nDeployment B" as iotB
component "Office\nLocation F" as lf

cld -down-> ea
cld -down-> eb
cld -down-> ec
cld -down-> ed
cld -down-> ee

ea -down-> la
ea -down-> lb
eb -down-> iotA
eb -down-> lc
ec -down-> ld
ed -down-> le
ee -down-> iotB
ee -down-> lf

note right of cld
  Heavier processing remains in the cloud.
  Lower-end processing moves to the edge,
  closer to users / devices, where it runs
  faster, more responsively, and at scale.
end note

note left of ea
  Each physical location has
  its own edge environment.
  Edge environments may be
  hosted in third-party locations
  (ISPs, telecom providers).
end note

note bottom of lf
  Benefits: reduced bandwidth,
  better resource utilization,
  improved security
  (encryption nearer origin),
  reduced power consumption.
end note

@enduml

