@startuml direct_io_access
!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title Direct I/O Access Architecture\nVirtual server bypasses the hypervisor to use the physical I/O card

actor "Cloud Service\nConsumers" as csc

node "Physical Server" as ps {
  component "Hypervisor\n(virtual switch)" as hv
  component "Physical\nI/O Card" as io
  component "Virtual Server" as vs
}

database "SAN Storage LUN\n(database)" as san

' Normal state path (1)
csc -down-> vs : (1) requests
vs -down-> hv : virtualized I/O
hv -down-> io : forwarded I/O
io -down-> san : storage access

' Problem and solution states
note left of hv
  (2) Request volume increases
  (3) Virtual switch bandwidth
      and performance become
      inadequate (bottleneck)
end note

' Direct path bypassing hypervisor
vs -right-> io : (4) direct path\n(bypass hypervisor)

note right of vs
  Solution: host CPU supports
  direct access; drivers installed
  on the virtual server so the
  I/O card is recognized as
  a hardware device.
end note

' Supporting mechanisms
package "Supporting Mechanisms" as mech {
  component "Cloud Usage Monitor" as cum
  component "Logical Network Perimeter" as lnp
  component "Pay-Per-Use Monitor" as ppm
  component "Resource Replication" as rr
}

mech .down.> ps : classify, isolate,\nmeter, replicate

@enduml
