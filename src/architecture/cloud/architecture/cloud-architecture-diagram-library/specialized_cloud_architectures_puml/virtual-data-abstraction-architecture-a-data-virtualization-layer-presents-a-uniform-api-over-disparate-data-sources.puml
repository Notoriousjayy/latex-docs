@startuml virtual_data_abstraction
!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title Virtual Data Abstraction Architecture\nA data virtualization layer presents a uniform API over disparate data sources

skinparam cloud {
  BackgroundColor #F4ECF7
  BorderColor #6C3483
}

cloud "Cloud A" as cldA {
  component "Cloud Application\nService A" as appA
}

component "Data Virtualization Layer\n(uniform data API,\nresolves structure differences)" as dvl

database "Data Source A" as dsA
database "Data Source B" as dsB
database "Data Source C" as dsC

package "On Premises" as onprem {
  database "Data Source D" as dsD
}

appA -down-> dvl : single,\nuniform API
dvl -down-> dsA
dvl -down-> dsB
dvl -down-> dsC
dvl -down-> dsD

note right of dvl
  Data exists virtually in the
  data virtualization software.
  Differences in format,
  structure, and schema are
  resolved here.
end note

note left of dvl
  Cloud applications form a
  loosely coupled relationship
  with disparate data sources.
  When sources change, the
  layer is updated; APIs to
  cloud applications stay stable.
end note

@enduml
