@startuml index_specialized_cloud_architectures
title Specialized Cloud Architectures - Index\nGrouping by major concern (Chapter 15)

skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 11
skinparam roundcorner 6
skinparam package {
  BackgroundColor #EAF2F8
  BorderColor #2874A6
}
skinparam rectangle {
  BackgroundColor #FDEBD0
  BorderColor #B9770E
}

package "Storage Access" as g1 {
  rectangle "15.1 Direct I/O Access" as a1
  rectangle "15.2 Direct LUN Access" as a2
  rectangle "15.8 Multipath Resource Access" as a8
}

package "Storage Tiering, Migration\nand Normalization" as g2 {
  rectangle "15.3 Dynamic Data Normalization" as a3
  rectangle "15.5 Cross-Storage Device\nVertical Tiering" as a5
  rectangle "15.6 Intra-Storage Device\nVertical Data Tiering" as a6
  rectangle "15.11 Storage Maintenance Window" as a11
}

package "Network Capacity\nand Resilience" as g3 {
  rectangle "15.4 Elastic Network Capacity" as a4
  rectangle "15.7 Load-Balanced\nVirtual Switches" as a7
  rectangle "15.9 Persistent Virtual\nNetwork Configuration" as a9
  rectangle "15.10 Redundant Physical\nConnection for Virtual Servers" as a10
}

package "Distributed Processing\n(Outside the Cloud)" as g4 {
  rectangle "15.12 Edge Computing" as a12
  rectangle "15.13 Fog Computing" as a13
}

package "Abstraction and Federation\n(Across Clouds)" as g5 {
  rectangle "15.14 Virtual Data Abstraction" as a14
  rectangle "15.15 Metacloud" as a15
  rectangle "15.16 Federated Cloud Application" as a16
}

g1 -[hidden]down- g2
g3 -[hidden]down- g4
g4 -[hidden]down- g5
g1 -[hidden]right- g3

@enduml
