@startuml load_balanced_virtual_switches
!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title Load-Balanced Virtual Switches Architecture\nMultiple uplinks (NIC team) distribute traffic to avoid bottlenecks

skinparam cloud {
  BackgroundColor #F4ECF7
  BorderColor #6C3483
}

actor "Cloud Service\nConsumers" as csc
cloud "External Network" as ext

node "Physical Server (Hypervisor)" as host {
  component "Virtual Server 1" as vs1
  component "Virtual Server 2" as vs2
  component "Virtual Server n" as vsn

  component "Virtual Switch\n(NIC team,\ntraffic-shaping policy)" as vsw

  component "Uplink NIC 1" as nic1
  component "Uplink NIC 2" as nic2
  component "Uplink NIC 3" as nic3

  component "Load Balancer\n(link aggregation)" as lb
}

vs1 -down-> vsw
vs2 -down-> vsw
vsn -down-> vsw

vsw -down-> lb : distribute
lb -down-> nic1
lb -down-> nic2
lb -down-> nic3

nic1 -down-> ext
nic2 -down-> ext
nic3 -down-> ext

csc -up-> ext

note right of lb
  Workload distributed across
  multiple uplinks simultaneously.
  No single NIC is overloaded.
end note

note left of host
  Supporting mechanisms:
  Cloud Usage Monitor,
  Hypervisor, Logical Network
  Perimeter, Resource Replication,
  Virtual Server.
end note

@enduml
