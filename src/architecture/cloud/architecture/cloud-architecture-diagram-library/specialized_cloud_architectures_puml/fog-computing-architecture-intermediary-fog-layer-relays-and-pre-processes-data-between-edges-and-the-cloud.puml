@startuml fog_computing
!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title Fog Computing Architecture\nIntermediary fog layer relays and pre-processes data between edges and the cloud

skinparam cloud {
  BackgroundColor #F4ECF7
  BorderColor #6C3483
}

cloud "Cloud" as cld

node "Fog A" as fa
node "Fog B" as fb
node "Fog C" as fc
node "Fog D" as fd
node "Fog E" as fe

node "Edge A" as ea
node "Edge B" as eb
node "Edge C" as ec
node "Edge D" as ed
node "Edge E" as ee
node "Edge F" as ef
node "Edge G" as eg
node "Edge H" as eh

component "Office\nLocation A" as la
component "Office\nLocation B" as lb
component "IoT\nDeployment A" as iotA
component "Office\nLocation C" as lc
component "Office\nLocation D" as ld
component "Office\nLocation E" as le
component "Office\nLocation F" as lf
component "IoT\nDeployment B" as iotB
component "Office\nLocation G" as lg

cld -down-> fa
cld -down-> fb
cld -down-> fc
cld -down-> fd
cld -down-> fe

fa -down-> ea
fa -down-> eb
fb -down-> ec
fb -down-> ed
fc -down-> ee
fd -down-> ef
fd -down-> eg
fe -down-> eh

ea -down-> la
eb -down-> lb
ec -down-> iotA
ec -down-> lc
ed -down-> ld
ee -down-> le
ef -down-> lf
eg -down-> iotB
eh -down-> lg

note right of cld
  Fog acts as gateway.
  When edges send large data volumes,
  the fog determines which data is
  most valuable and forwards critical
  data to the cloud first.
  Lower-priority data may be
  processed locally in the fog.
end note

note left of fa
  Each fog environment can support
  and facilitate multiple edges.
  Common in IoT and in highly
  distributed business automation.
end note

@enduml
