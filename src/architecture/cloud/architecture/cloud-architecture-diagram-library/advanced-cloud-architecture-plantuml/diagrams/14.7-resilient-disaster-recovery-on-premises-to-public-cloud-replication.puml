@startuml
' ============================================================
' Diagram   : Resilient Disaster Recovery - Replication Topology
' Section   : 14.7 Resilient Disaster Recovery Architecture
' Type      : Deployment diagram
' Message   : Resource and storage replication keep cloud-based
'             redundant copies of on-premises critical
'             resources in sync, ready to take over after
'             a disaster.
' ============================================================

title 14.7 Resilient Disaster Recovery\nOn-Premises to Public Cloud Replication

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam roundCorner 6
skinparam ArrowColor #555555
skinparam ComponentBackgroundColor #F0F4F8
skinparam ComponentBorderColor #4A6B8A
skinparam NodeBackgroundColor #FAFCFD
skinparam NodeBorderColor #4A6B8A
skinparam DatabaseBackgroundColor #F0F4F8
skinparam DatabaseBorderColor #4A6B8A
skinparam CloudBackgroundColor #F8FAFC
skinparam CloudBorderColor #4A6B8A
skinparam PackageBackgroundColor #EAF2FB
skinparam PackageBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

package "Organization (on-premises)" as Org {
  node "Physical Server" as PS1
  node "Physical Server" as PS2
  node "Physical Server" as PS3
  rectangle "Virtual\nServer" as oVS1
  rectangle "Virtual\nServer" as oVS2
  rectangle "Virtual\nServer" as oVS3
  database "Storage\nDevice" as SD1
  database "Shared\nStorage" as SHS
  database "Storage\nDevice" as SD2
  PS1 -- oVS1
  PS2 -- oVS2
  PS3 -- oVS3
}

cloud "Public Cloud (secondary site)" as PC {
  node "Hypervisor Host" as HH {
    rectangle "Virtual Server\n(replica)" as VS1
    rectangle "Virtual Server\n(replica)" as VS2
    rectangle "Virtual Server\n(replica)" as VS3
  }
  database "Cloud Storage\nDevice (replica)" as CSD
}

oVS1 ==> VS1 : resource\nreplication
oVS2 ==> VS2 : resource\nreplication
oVS3 ==> VS3 : resource\nreplication
SHS ==> CSD : storage\nreplication

note right of PC
  Cloud ubiquitous-access and resiliency
  characteristics support always-available
  redundancy that takes over when the
  primary site is destroyed or degraded.
end note

note bottom of PC
  Mechanisms: hypervisor, virtual server, cloud
  storage device, resource replication, storage
  replication.
end note

@enduml
