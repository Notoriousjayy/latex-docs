@startuml
' ============================================================
' Diagram   : Zero Downtime - Failover Group
' Section   : 14.5 Zero Downtime Architecture
' Type      : Deployment diagram
' Message   : A fault-tolerance system in an active-active
'             physical-server group migrates virtual servers
'             from a failed host to a secondary host without
'             interruption.
' ============================================================

!include ../../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title 14.5 Zero Downtime\nActive-Active Failover Group

skinparam ComponentBackgroundColor #F0F4F8
skinparam ComponentBorderColor #4A6B8A
skinparam NodeBackgroundColor #FAFCFD
skinparam NodeBorderColor #4A6B8A
skinparam DatabaseBackgroundColor #F0F4F8
skinparam DatabaseBorderColor #4A6B8A
skinparam FrameBackgroundColor #FAFCFD
skinparam FrameBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

frame "Active-Active Resource Cluster (Failover Group)" as Group {
  node "Physical Server A\n(failed)" as PSA {
    component "Hypervisor" as HVA
    rectangle "Virtual\nServer A" as VSA
  }

  node "Physical Server B" as PSB {
    component "Hypervisor" as HVB
    rectangle "Virtual\nServer A'" as VSAp
  }

  database "Shared Volume\n(persistent virtual\nnetwork config)" as Vol
}

component "Failover System" as FS
component "Live VM\nMigration" as LVM

HVA --> Vol
HVB --> Vol

FS -[#B22222]-> LVM : trigger
LVM -[#B22222]-> VSA : evacuate
LVM -[#B22222]-> VSAp : reinstantiate

note bottom of Group
  All virtual servers are stored on a shared volume so any
  physical server in the group can access their files.
end note

note right of FS
  Mechanisms: failover system, cloud storage device,
  virtual server, audit monitor, cloud usage monitor,
  hypervisor, logical network perimeter,
  resource cluster, resource replication.
end note

@enduml
