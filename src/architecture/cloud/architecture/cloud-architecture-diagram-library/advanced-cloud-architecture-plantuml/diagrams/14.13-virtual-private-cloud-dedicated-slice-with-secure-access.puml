@startuml
' ============================================================
' Diagram   : Virtual Private Cloud - Dedicated Slice
' Section   : 14.13 Virtual Private Cloud Architecture
' Type      : Deployment diagram
' Message   : Dedicated physical resources within a public
'             cloud are isolated and made exclusively available
'             to one cloud consumer, accessed via a secure VPN
'             (or, optionally, a dedicated physical link).
' ============================================================

!include ../../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

title 14.13 Virtual Private Cloud\nDedicated Slice with Secure Access

skinparam ComponentBackgroundColor #F0F4F8
skinparam ComponentBorderColor #4A6B8A
skinparam NodeBackgroundColor #FAFCFD
skinparam NodeBorderColor #4A6B8A
skinparam DatabaseBackgroundColor #F0F4F8
skinparam DatabaseBorderColor #4A6B8A
skinparam CloudBackgroundColor #F8FAFC
skinparam CloudBorderColor #4A6B8A
skinparam PackageBackgroundColor #EAF2FB
skinparam PackageBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

actor "Cloud Consumer\n(exclusive owner)" as CC

cloud "Public Cloud Provider Infrastructure" as Cloud {

  package "Virtual Private Cloud\n(dedicated to one consumer)" as VPC {
    node "Physical Servers" as DPS
    component "Hypervisor" as DH
    rectangle "Virtual Server" as DVS
    component "Virtual Switch" as DVSW
    artifact "CPU" as DCPU
    artifact "RAM" as DRAM
    database "Cloud Storage\nDevice" as DSD
    component "Network Device\n(separate physical\nnetwork)" as DND
    DPS -- DH
    DH -- DVS
    DVS -- DVSW
  }

  package "Shared resources\n(other consumers)" as Shared {
    node "Physical Servers" as SPS
    artifact "CPU" as SCPU
    artifact "RAM" as SRAM
    database "Storage Device" as SSD
    component "Network Device" as SND
  }
}

CC -[#1F4E79]-> VPC : VPN\n(or dedicated\nphysical link)

note right of VPC
  VPC physical resources are isolated
  from the rest of the provider's
  infrastructure, including a
  separate physical network.
end note

note bottom of VPC
  Mechanisms: hypervisor, virtual server,
  cloud storage device, virtual switch.
  VPN is normally NOT required when a
  private cloud sits within the
  organization's own physical boundary.
end note

@enduml
