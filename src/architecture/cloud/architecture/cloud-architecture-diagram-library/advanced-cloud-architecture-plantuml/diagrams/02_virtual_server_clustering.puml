@startuml
' ============================================================
' Diagram   : Virtual Server Clustering - Structural View
' Section   : 14.2 Virtual Server Clustering Architecture
' Type      : Deployment diagram
' Message   : The resource cluster mechanism configures virtual
'             servers (across hypervisors on multiple physical
'             hosts) into clusters of virtual servers.
' ============================================================

title 14.2 Virtual Server Clustering\nStructural View

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam roundCorner 6
skinparam ArrowColor #555555
skinparam ComponentBackgroundColor #F0F4F8
skinparam ComponentBorderColor #4A6B8A
skinparam NodeBackgroundColor #FAFCFD
skinparam NodeBorderColor #4A6B8A
skinparam FrameBackgroundColor #FAFCFD
skinparam FrameBorderColor #4A6B8A
skinparam PackageBackgroundColor #EAF2FB
skinparam PackageBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

node "Physical Server A" as PSA {
  component "Hypervisor" as HVA
  rectangle "VS A1" as A1
  rectangle "VS B1" as B1
}
HVA -- A1
HVA -- B1

node "Physical Server B" as PSB {
  component "Hypervisor" as HVB
  rectangle "VS A2" as A2
  rectangle "VS C1" as C1
}
HVB -- A2
HVB -- C1

node "Physical Server C" as PSC {
  component "Hypervisor" as HVC
  rectangle "VS B2" as B2
  rectangle "VS D1" as D1
}
HVC -- B2
HVC -- D1

frame "Resource Cluster Mechanism" as RC {
  package "Cluster A" as CA
  package "Cluster B" as CB
  package "Cluster C" as CC
  package "Cluster D" as CD
}

A1 ..> CA
A2 ..> CA
B1 ..> CB
B2 ..> CB
C1 ..> CC
D1 ..> CD

note bottom of RC
  Logical Network Perimeter encloses each cluster
  for secure intra-cluster communication.
  Resource Replication propagates status, availability
  and configuration changes across cluster nodes.
end note

@enduml
