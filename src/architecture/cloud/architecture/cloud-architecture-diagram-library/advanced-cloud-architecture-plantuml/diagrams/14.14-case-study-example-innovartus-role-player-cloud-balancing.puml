@startuml
' ============================================================
' Diagram   : Case Study - Innovartus Role Player Cloud Balancing
' Section   : 14.14 Case Study Example
' Type      : Component diagram
' Message   : Innovartus deploys a cloud-balanced Role Player
'             with a central load balancer, per-cloud automated
'             scaling listeners, per-cloud failover system
'             monitors, and intercloud failover between two
'             cloud providers.
' ============================================================

!include ../../../../../../../tooling/styles/plantuml/interaction/sequence-diagram-style.iuml

title 14.14 Case Study Example\nInnovartus Role Player Cloud Balancing

skinparam ComponentBackgroundColor #F0F4F8
skinparam ComponentBorderColor #4A6B8A
skinparam ActorBackgroundColor #F0F4F8
skinparam ActorBorderColor #4A6B8A
skinparam CloudBackgroundColor #F8FAFC
skinparam CloudBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

actor "Cloud Service\nConsumers" as CSC
component "Load Balancer\n(service agent)" as LB

cloud "Cloud A\n(global cloud provider)" as CA {
  component "Automated\nScaling Listener" as ASL_A
  rectangle "Role Player\n(replicated\ncloud services)" as RP_A
  rectangle "Ready-Made\nEnvironment" as RME_A
  component "Failover System\nMonitor" as FSM_A
  RP_A -- RME_A
}

cloud "Cloud B\n(regional cloud provider)" as CB {
  component "Automated\nScaling Listener" as ASL_B
  rectangle "Role Player\n(replicated\ncloud services)" as RP_B
  rectangle "Ready-Made\nEnvironment" as RME_B
  component "Failover System\nMonitor" as FSM_B
  RP_B -- RME_B
}

CSC --> LB : 1. requests
LB --> ASL_B : 2A. route
LB --> ASL_A : 2B. route
ASL_A --> RP_A : 3. forward
ASL_B --> RP_B : 3. forward
FSM_A ..> RP_A : 4. detect\n& respond
FSM_B ..> RP_B : 4. detect\n& respond

FSM_A <-[#B22222]-> FSM_B : intercloud\nfailover

note right of LB
  Routes consumer requests across
  clouds using a predefined
  workload distribution algorithm.
end note

note bottom of CB
  Intercloud failover is carried out primarily
  when local cloud service implementations
  are nearing their processing thresholds, or
  when a cloud encounters a severe platform failure.
end note

@enduml

