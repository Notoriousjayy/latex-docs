@startuml
' ============================================================
' Diagram   : Resource Reservation - Borrow & Release Flow
' Section   : 14.9 Resource Reservation Architecture
' Type      : Activity diagram
' Message   : The resource management system enforces per-pool
'             reservation limits, allowing controlled borrowing
'             and reclaiming reserved IT resources when their
'             owner needs them.
' ============================================================

!include ../../../../../../../tooling/styles/plantuml/behavioral/activity-diagram-style.iuml

title 14.9 Resource Reservation\nBorrow and Reclaim Flow

skinparam ActivityBackgroundColor #F0F4F8
skinparam ActivityBorderColor #4A6B8A
skinparam ActivityDiamondBackgroundColor #FFF8DC
skinparam ActivityDiamondBorderColor #4A6B8A
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #999999

start
:1. Create physical resource group;
:2. Create parent resource pool;
:3. Create child Pool 1 and Pool 2\nand define reservation limits\nin the resource management system;
:4. Grant Cloud Consumer A access to Pool 1;
:4. Grant Cloud Consumer B access to Pool 2;

repeat
  :Cloud consumers issue requests;

  if (5. Pool 1 demand exceeds Pool 1 capacity?) then (yes)
    :Borrow IT resources\nfrom Pool 2\n(bounded by Pool 2's\nreservation limit);
    note right
      Borrowing is confined by the
      reservation limit defined in
      step 3 so Pool 2's owner is
      protected from constraints.
    end note
  else (no)
    :Continue normal operation;
  endif

  if (7. Pool 2 owner now needs reserved capacity?) then (yes)
    :8. Resource management system\nforces Pool 1 to release;
    :Return IT resources to Pool 2;
  else (no)
    :Continue normal operation;
  endif
repeat while (system running?) is (yes) not (no)
stop

note right
  Reservable types: cloud storage devices,
  virtual servers.
  Mechanisms: resource management system,
  remote administration system,
  audit monitor, cloud usage monitor,
  hypervisor, logical network perimeter,
  resource replication.
end note

@enduml
