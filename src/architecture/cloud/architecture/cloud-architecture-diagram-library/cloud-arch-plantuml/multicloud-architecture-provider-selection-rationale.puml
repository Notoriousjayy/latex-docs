@startuml
title Multicloud Architecture - Provider Selection Rationale

!include ../../../../../../tooling/styles/plantuml/structural/package-diagram-style.iuml

rectangle "Cloud Consumer" as CC

package "Reasons to Select One Provider over Another" as Reasons {
  rectangle "Geographical\n(local providers for\nregulatory purposes)" as Geo
  rectangle "Economic\n(prices or\nbilling models)" as Eco
  rectangle "Operational\n(higher capacity,\nresiliency, performance)" as Op
  rectangle "Functional\n(more features, specific\ncapabilities, quality)" as Fn
}

rectangle "Avoid Vendor Lock-In\n(no dependency on\nsingle provider)" as Lockin

package "Business Benefits" as Benefits {
  rectangle "Maximize\nbusiness agility" as Agility
  rectangle "Faster delivery\nof new products" as Delivery
  rectangle "Optimize cloud apps\nand automated operations" as Optim
  rectangle "Mix and match\ncompeting providers" as Mix
}

CC --> Reasons : evaluates
CC --> Lockin : motivated by
Reasons --> Benefits : enable
Lockin --> Benefits : enables

@enduml
