@startuml
title Resource Pooling Architecture - Involved Mechanisms

!include ../../../../../../tooling/styles/plantuml/structural/deployment-diagram-style.iuml

package "Resource Pool Environment" as RPE {

  package "Pooled IT Resources" as Pooled {
    component "Cloud Storage Devices" as CSD
    component "Virtual Servers" as VS
  }

  package "Mechanisms" as Mechs {
    component "Audit Monitor" as AM
    component "Cloud Usage Monitor" as CUM
    component "Hypervisor" as HV
    component "Logical Network\nPerimeter" as LNP
    component "Pay-Per-Use Monitor" as PPM
    component "Remote Administration\nSystem" as RAS
    component "Resource Management\nSystem" as RMS
    component "Resource Replication" as RR
  }
}

actor "Cloud Consumer" as CC

AM --> Pooled : compliance,\nprivacy/regulation
CUM --> Pooled : runtime tracking,\nsynchronization
HV --> VS : provides access\nto pools
LNP --> Pooled : organize and\nisolate
PPM --> CC : usage and\nbilling info
RAS --> RMS : interfaces via\nfront-end portal
RMS --> CC : pool admin\ntools / permissions
RR --> Pooled : generates\nnew instances

note right of HV
  Hypervisor hosts the virtual servers
  and sometimes the resource pools
  themselves.
end note

@enduml
