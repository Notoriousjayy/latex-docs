@startuml
title Cloud Bursting Architecture - Burst Decision Flow

skinparam shadowing false
skinparam activity {
  BackgroundColor #F7F9FC
  BorderColor #4A6FA5
  DiamondBackgroundColor #F7F9FC
  DiamondBorderColor #4A6FA5
}

start
:Service consumers send requests;
:Automated scaling listener monitors\non-premises usage;

if (Capacity threshold exceeded?) then (yes)
  :Burst-out: redirect excess requests\nto cloud-based redundant implementation;
  :Resource replication keeps\nstate synchronized between\non-premises and cloud;
  :Pay-per-use monitor tracks\ncloud usage for billing;

  while (Demand still elevated?) is (yes)
    :Continue serving from cloud;
  endwhile (no)

  :Burst-in: release cloud-based\nIT resources;
  :On-premises implementation\nresumes processing;
  :No additional cloud-related\nusage fees incurred;
else (no)
  :Continue on-premises processing;
endif

stop

@enduml
