@startuml
title Multicloud Architecture - Resources Distributed Across Public Clouds

!include ../../../../../../tooling/styles/plantuml/interaction/sequence-diagram-style.iuml

package "Organization (Cloud Consumer)" as Org {
  actor "Cloud Resource\nAdministrator" as CRA
  rectangle "Centralized Remote\nAdministration System" as CRAS
}

cloud "Cloud A" as CA {
  component "Storage" as StorageA
  component "Management\nSystem A" as MSA
  rectangle "API A" as APIA
}

cloud "Cloud B" as CB {
  component "Processing" as ProcB
  component "Management\nSystem B" as MSB
  rectangle "API B" as APIB
}

cloud "Cloud C" as CC {
  component "Cloud Services" as SvcC
  component "Management\nSystem C" as MSC
  rectangle "API C" as APIC
}

CRA --> CRAS
CRAS --> APIA : connect
CRAS --> APIB : connect
CRAS --> APIC : connect
APIA --> MSA
APIB --> MSB
APIC --> MSC
MSA --> StorageA
MSB --> ProcB
MSC --> SvcC

note bottom of Org
  Resources may be offered through
  IaaS, PaaS, or SaaS delivery models.
end note

note right of CRAS
  Allows the cloud consumer to manage
  all cloud-based IT resources from a
  central location as if they were from
  a single cloud.
end note

@enduml

