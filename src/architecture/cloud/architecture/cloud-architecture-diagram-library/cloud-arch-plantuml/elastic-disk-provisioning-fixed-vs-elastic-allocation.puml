@startuml
title Elastic Disk Provisioning - Fixed vs Elastic Allocation

!include ../../../../../../tooling/styles/plantuml/structural/package-diagram-style.iuml

package "Fixed-Disk Allocation (baseline)" as Fixed {
  rectangle "Virtual Server\nrequest: 3 x 150 GB" as VS1
  rectangle "Provisioned: 450 GB\nUsed: 0 GB\nAllocated: 450 GB" as State1
  rectangle "Billing:\ncharged for 450 GB\nfrom point of allocation" as Bill1
  VS1 --> State1
  State1 --> Bill1
}

package "Elastic Disk Provisioning" as Elastic {
  rectangle "Virtual Server\nrequest: 3 x 150 GB" as VS2
  rectangle "Provisioned: 450 GB (max)\nUsed: 0 GB\nAllocated: 0 GB" as State2
  rectangle "Billing:\ncharged for actual\nused storage only" as Bill2
  VS2 --> State2
  State2 --> Bill2
}

package "Supporting Mechanisms" as Mechs {
  component "Cloud Storage Device" as CSD
  component "Virtual Server" as VS
  component "Hypervisor" as HV
  component "Pay-Per-Use Monitor" as PPM
  component "Cloud Usage Monitor" as CUM
  component "Resource Replication" as RR
}

Elastic ..> Mechs : uses

note bottom of Mechs
  Resource replication is used when
  conversion of dynamic thin-disk storage
  into static thick-disk storage is
  required.
end note

@enduml
