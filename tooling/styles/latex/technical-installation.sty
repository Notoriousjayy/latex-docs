% =============================================================================
% technical-installation.sty
% =============================================================================
% Role in the hierarchy: CONCRETE SUBTYPE.
% Generalizes from: latex-docs-technical -> latex-docs-base.
%
% Functional class served:
%   Installation instructions, deployment runbooks, environment setup guides,
%   and bootstrap procedures.
%
% Specialization contributed beyond the abstract technical module:
%   * `prerequisites` checklist environment with \Prereq{...} bullets, each
%     prefaced by an open-checkbox glyph so a reader can tick them off.
%   * `installsteps` numbered ordered-steps environment, where each \IStep is
%     a self-contained block: an action, an optional verification, and an
%     optional rollback note.
%   * \EnvVar{NAME=value}: a typographic convention for environment variables.
%   * `rollback` tcolorbox -- a brick-framed callout dedicated to undoing a
%     step or stage if installation fails partway through.
%
% Sets \DocClass = "Technical / Installation Instructions".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-technical-installation}%
  [2026/05/08 v1.0 latex-docs technical installation instructions subtype]

\RequirePackage{latex-docs-technical}
\LdsRegisterModule{technical-installation}%
                  {Technical / Installation Instructions}

% -----------------------------------------------------------------------------
% 1. Prerequisites checklist
% -----------------------------------------------------------------------------
\newenvironment{prerequisites}{%
  \subsection*{Prerequisites}%
  \begin{itemize}[leftmargin=2em,topsep=2pt,itemsep=2pt,
                  label={\textcolor{Steel}{$\square$}}]%
}{%
  \end{itemize}
}
\newcommand{\Prereq}[1]{\item #1}

% -----------------------------------------------------------------------------
% 2. Installation steps
% -----------------------------------------------------------------------------
\NewLdsCounter{InstallStep}{installation steps}{step}

% Each \IStep takes:
%   #1 -- short action title (becomes a subsection-like header)
%   #2 -- the action body (commands, screenshots, narrative)
% Inside the body, the author may use \Verify{...} and \RollbackNote{...}
% for the optional secondary fields. They are environment-local commands.
\newcommand{\IStep}[2]{%
  \refstepcounter{LdsInstallStep}%
  \par\noindent
  \begin{tcolorbox}[colback=Soft,colframe=Steel,boxrule=0.4pt,arc=2pt,
                    left=3mm,right=3mm,top=1.5mm,bottom=1.5mm,
                    title=\textbf{Step \theLdsInstallStep~--~#1},
                    coltitle=white,fonttitle=\bfseries]%
    #2
  \end{tcolorbox}\par
}

\newcommand{\Verify}[1]{%
  \par\smallskip\noindent\textbf{\textcolor{Teal}{Verify.}}\enspace #1\par
}
\newcommand{\RollbackNote}[1]{%
  \par\smallskip\noindent\textbf{\textcolor{Brick}{Rollback.}}\enspace #1\par
}

% -----------------------------------------------------------------------------
% 3. Rollback callout (top-level, separate from step-local rollback note)
% -----------------------------------------------------------------------------
\@ifundefined{rollback}{%
  \newtcolorbox{rollback}[1][Rollback]{title=\textbf{#1},colframe=Brick,
    colback=Soft,coltitle=white,fonttitle=\bfseries,
    leftrule=4pt}%
}{}

% -----------------------------------------------------------------------------
% 4. Environment-variable typography
% -----------------------------------------------------------------------------
\providecommand{\EnvVar}[1]{\texttt{\textcolor{Navy}{#1}}}

\endinput



