% =============================================================================
% latex-docs-technical-testing.sty
% =============================================================================
% Role in the hierarchy: CONCRETE SUBTYPE.
% Generalizes from: latex-docs-technical -> latex-docs-base.
%
% Functional class served:
%   Test plans, test procedures, test cases, and acceptance-test artifacts.
%
% Specialization contributed beyond the abstract technical module:
%   * \TestCase{TC-001}{Title}: a labelable, label-numbered test header.
%   * `testcase` environment: standard Steps / Expected / Actual / Status
%     layout in a tcolorbox.
%   * \Pass / \Fail / \Skip / \Block: status glyphs in palette colours.
%   * `coverage` matrix: requirement -> covering test cases.
%   * \Precondition{...} / \Postcondition{...}: inline conditions for setup
%     and teardown.
%
% Sets \DocClass = "Technical / Testing Procedures".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-technical-testing}%
  [2026/05/08 v1.0 latex-docs technical testing procedures subtype]

\RequirePackage{latex-docs-technical}
\LdsRegisterModule{technical-testing}{Technical / Testing Procedures}

% -----------------------------------------------------------------------------
% 1. Status glyphs
% -----------------------------------------------------------------------------
\providecommand{\Pass}{\textcolor{Teal}{\textbf{PASS}}}
\providecommand{\Fail}{\textcolor{Brick}{\textbf{FAIL}}}
\providecommand{\Skip}{\textcolor{Steel}{\textbf{SKIP}}}
\providecommand{\Block}{\textcolor{Brick}{\textbf{BLOCKED}}}

% -----------------------------------------------------------------------------
% 2. Test case header and environment
% -----------------------------------------------------------------------------
\newcommand{\TestCase}[2]{%
  \par\noindent\textbf{\textcolor{Navy}{#1}}\quad #2\par
}

\newenvironment{testcase}[2]{%
  \par\noindent
  \begin{tcolorbox}[colback=Soft,colframe=Steel,boxrule=0.4pt,arc=2pt,
                    left=3mm,right=3mm,top=1.5mm,bottom=1.5mm,
                    title=\textbf{#1~--~#2},coltitle=white,fonttitle=\bfseries]%
}{%
  \end{tcolorbox}\par
}

\newcommand{\Precondition}[1]{%
  \par\noindent\textbf{Preconditions.}\enspace #1\par
}
\newcommand{\Postcondition}[1]{%
  \par\noindent\textbf{Postconditions.}\enspace #1\par
}

% -----------------------------------------------------------------------------
% 3. Test step / expected / actual / status table
% -----------------------------------------------------------------------------
% Reuses the abstract module's stepresult environment? No -- testing needs
% an additional Actual + Status column, so we declare a sibling environment
% named teststeps. Both sit comfortably together; documents pick the right
% one for the use case.
\NewLdsCounter{TestStep}{test steps}{step}

\newenvironment{teststeps}{%
  \setcounter{LdsTestStep}{0}%
  \par
  \begin{longtable}{@{}l>{\raggedright\arraybackslash}p{0.30\linewidth}%
                       >{\raggedright\arraybackslash}p{0.24\linewidth}%
                       >{\raggedright\arraybackslash}p{0.18\linewidth}l@{}}
    \toprule
    \textbf{\#} & \textbf{Action} & \textbf{Expected} &
    \textbf{Actual} & \textbf{Status}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\TStep}[4]{%
  \refstepcounter{LdsTestStep}%
  \theLdsTestStep & #1 & #2 & #3 & #4\\
}

% -----------------------------------------------------------------------------
% 4. Coverage matrix
% -----------------------------------------------------------------------------
\newenvironment{coverage}{%
  \par
  \begin{longtable}{@{}>{\raggedright\arraybackslash}p{0.16\linewidth}%
                       >{\raggedright\arraybackslash}p{0.42\linewidth}%
                       >{\raggedright\arraybackslash}p{0.30\linewidth}@{}}
    \toprule
    \textbf{Req ID} & \textbf{Statement} & \textbf{Covering test cases}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\Cov}[3]{#1 & #2 & #3\\}

\endinput



