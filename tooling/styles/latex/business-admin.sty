% =============================================================================
% business-admin.sty
% =============================================================================
% Role in the hierarchy: CONCRETE FAMILY MODULE.
% Generalizes from: base.sty.
%
% Functional class served:
%   Memos, meeting minutes, status reports, policies, procedures (SOPs), and
%   internal-administrative documents that communicate decisions, actions,
%   and operational guidance.
%
% Specialization contributed beyond the parent:
%   * \memoheader{To}{From}{Re}{Date}: classic four-line memo header rendered
%     in a steel-framed tcolorbox.
%   * `attendees` and `agenda` environments for meeting minutes, with sensible
%     enumerate styling and section breaks.
%   * `decisions` and `actionitems` environments tied to the parent counter
%     factory so each decision and action gets a stable, label-able id.
%   * \Decision{...}, \ActionItem{Owner}{Due}{Description}: numbered entries
%     consistent with the family typography.
%   * `policy` and `procedure` environments for SOPs: numbered, ordered steps
%     with optional rationale and verification rows.
%
% The module sets \DocClass = "Business / Administrative".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{business-admin}%
  [2026/05/08 v1.0 latex-docs business and administrative family module]

\RequirePackage{base}
\LdsRegisterModule{business-admin}{Business / Administrative}

% -----------------------------------------------------------------------------
% 1. Memo header
% -----------------------------------------------------------------------------
% \memoheader{To}{From}{Re}{Date}
\newcommand{\memoheader}[4]{%
  \par\noindent
  \begin{tcolorbox}[colback=Soft,colframe=Steel,boxrule=0.5pt,arc=2pt,
                    left=4mm,right=4mm,top=2mm,bottom=2mm]%
    \begin{tabular}{@{}p{0.12\linewidth}p{0.78\linewidth}@{}}
      \textbf{To:}   & #1\\
      \textbf{From:} & #2\\
      \textbf{Re:}   & #3\\
      \textbf{Date:} & #4\\
    \end{tabular}
  \end{tcolorbox}
  \par
}

% -----------------------------------------------------------------------------
% 2. Meeting-minutes environments
% -----------------------------------------------------------------------------
\newenvironment{attendees}{%
  \subsection*{Attendees}
  \begin{itemize}[leftmargin=1.6em,topsep=2pt,itemsep=2pt]
}{%
  \end{itemize}
}

\newenvironment{agenda}{%
  \subsection*{Agenda}
  \begin{enumerate}[leftmargin=1.8em,topsep=2pt,itemsep=2pt,
                   label=\arabic*.,ref=\arabic*]
}{%
  \end{enumerate}
}

% -----------------------------------------------------------------------------
% 3. Decisions and action items
% -----------------------------------------------------------------------------
\NewLdsCounter{Decision}{decisions}{decision}
\NewLdsCounter{ActionItem}{action items}{action item}

\newenvironment{decisions}{%
  \subsection*{Decisions}
  \begin{description}[leftmargin=2em,style=nextline]
}{%
  \end{description}
}
\newcommand{\Decision}[1]{%
  \refstepcounter{LdsDecision}%
  \item[\textbf{D-\theLdsDecision.}] #1
}

\newenvironment{actionitems}{%
  \subsection*{Action items}
  \par
  \begin{longtable}{@{}l>{\raggedright\arraybackslash}p{0.16\linewidth}%
                       >{\raggedright\arraybackslash}p{0.14\linewidth}%
                       >{\raggedright\arraybackslash}p{0.42\linewidth}@{}}
    \toprule
    \textbf{ID} & \textbf{Owner} & \textbf{Due} & \textbf{Description}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\ActionItem}[3]{%
  \refstepcounter{LdsActionItem}%
  A-\theLdsActionItem & #1 & #2 & #3\\
}

% -----------------------------------------------------------------------------
% 4. Policy / Procedure / SOP environments
% -----------------------------------------------------------------------------
\NewLdsCounter{ProcedureStep}{procedure steps}{procedure step}

\newenvironment{policy}[1]{%
  \par\medskip
  \noindent\textbf{Policy.} #1\par\smallskip
  \begin{description}[leftmargin=1.6em,style=nextline]
}{%
  \end{description}
}

% \begin{procedure}{Title}  ...  \end{procedure}
% Inside, use \PStep{Description}{Verification}.
\newenvironment{procedure}[1]{%
  \subsection*{Procedure: #1}%
  \setcounter{LdsProcedureStep}{0}%
  \par
  \begin{longtable}{@{}l>{\raggedright\arraybackslash}p{0.46\linewidth}%
                       >{\raggedright\arraybackslash}p{0.32\linewidth}@{}}
    \toprule
    \textbf{Step} & \textbf{Action} & \textbf{Verification}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\PStep}[2]{%
  \refstepcounter{LdsProcedureStep}%
  \theLdsProcedureStep & #1 & #2\\
}

\endinput



