% =============================================================================
% latex-docs-technical-implementation.sty
% =============================================================================
% Role in the hierarchy: CONCRETE SUBTYPE.
% Generalizes from: latex-docs-technical -> latex-docs-base.
%
% Functional class served:
%   Implementation guides: "how to build this" documentation read by the
%   engineers writing the code -- code walkthroughs, API-contract narratives,
%   sequence-by-sequence explanations of how the implementation realises the
%   design.
%
% Specialization contributed beyond the abstract technical module:
%   * \APIContract{name}{kind}: an inline header for an API entry point, paired
%     with an `apicontract` environment that lays out Inputs / Outputs /
%     Errors / Side effects.
%   * \CodeRef{file}{lineno}{caption}: a small typeset reference to a specific
%     source line for narrative pointers ("see config.c:42").
%   * `walkthrough` numbered enumeration tuned for code-walking narratives,
%     where each \WStep starts a paragraph and is hard-aligned with the code
%     listings around it.
%   * Convention macros: \Module{...}, \Function{...}, \TypeName{...}.
%
% Sets \DocClass = "Technical / Implementation Guidance".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-technical-implementation}%
  [2026/05/08 v1.0 latex-docs technical implementation guidance subtype]

\RequirePackage{latex-docs-technical}
\LdsRegisterModule{technical-implementation}%
                  {Technical / Implementation Guidance}

% -----------------------------------------------------------------------------
% 1. API contract
% -----------------------------------------------------------------------------
\newcommand{\APIContract}[2]{%
  \par\noindent
  \textbf{\textcolor{Navy}{#1}}\quad
  \tcbox[on line,colback=Teal!10,colframe=Teal,coltext=Teal,boxsep=1pt,
         left=4pt,right=4pt,top=1pt,bottom=1pt,arc=2pt,boxrule=0.4pt]{%
    \footnotesize\bfseries #2}\par
}

\newenvironment{apicontract}[2]{%
  \APIContract{#1}{#2}%
  \begin{description}[leftmargin=2em,style=nextline,topsep=2pt,itemsep=2pt]
}{%
  \end{description}\par
}
\newcommand{\Inputs}{\item[\textbf{Inputs}]}
\newcommand{\Outputs}{\item[\textbf{Outputs}]}
\newcommand{\Errors}{\item[\textbf{Errors}]}
\newcommand{\SideEffects}{\item[\textbf{Side effects}]}

% -----------------------------------------------------------------------------
% 2. CodeRef -- inline source-line references
% -----------------------------------------------------------------------------
% \CodeRef{src/foo.c}{142}{the resize hook}
\newcommand{\CodeRef}[3]{%
  \mbox{\texttt{\small #1}:\textcolor{Teal}{#2}}\,#3%
}

% -----------------------------------------------------------------------------
% 3. Code walkthrough
% -----------------------------------------------------------------------------
\NewLdsCounter{Walkthrough}{walkthrough steps}{walkthrough step}

\newenvironment{walkthrough}[1]{%
  \subsection*{Walkthrough: #1}%
  \setcounter{LdsWalkthrough}{0}%
  \par
}{%
  \par\medskip
}
\newcommand{\WStep}[1]{%
  \refstepcounter{LdsWalkthrough}%
  \par\noindent\textbf{\theLdsWalkthrough.}\enspace #1\par
}

% -----------------------------------------------------------------------------
% 4. Semantic source-element typography
% -----------------------------------------------------------------------------
\providecommand{\Module}[1]{\texttt{\textcolor{Navy}{#1}}}
\providecommand{\Function}[1]{\texttt{\textcolor{Steel}{#1()}}}
\providecommand{\TypeName}[1]{\texttt{\textcolor{Teal}{#1}}}

\endinput
