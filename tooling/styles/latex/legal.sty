% =============================================================================
% latex-docs-legal.sty
% =============================================================================
% Role in the hierarchy: CONCRETE FAMILY MODULE.
% Generalizes from: latex-docs-base (the parent / hierarchy root).
%
% Functional class served:
%   Contracts, agreements, licenses, permits, NDAs, MOUs, statements of work,
%   and similar instruments that define obligations, rights, approvals, or
%   formal commitments between parties.
%
% Specialization contributed beyond the parent:
%   * Article / Clause / Recital semantic numbering (with cleveref support).
%   * \Parties{...}{...} and \PartyShort{...} for named-party introduction.
%   * `recitals` and `definitions` environments matching legal drafting
%     conventions.
%   * `clausebox`, `articlebox`, `recitalbox` labeled callouts via the parent
%     environment factory.
%   * \makesignaturepanel{Party A}{Party B}: two-column ruled signature
%     panel sized for an 8.5" page, printed at the foot of the document.
%   * \DefinedTerm{...}: typographic convention for terms-of-art (small caps,
%     navy-tinted), so a contract reads: "the \DefinedTerm{Licensee} shall...".
%
% The module sets \DocClass = "Legal Document" automatically. Documents that
% want a more specific label may override after \usepackage.
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-legal}%
  [2026/05/08 v1.0 latex-docs legal family module]

\RequirePackage{latex-docs-base}
\LdsRegisterModule{legal}{Legal Document}

% -----------------------------------------------------------------------------
% 1. Article / Clause / Recital numbering
%
% Articles are top-level (Article 1, 2, 3); clauses nest within (1.1, 1.2);
% recitals use roman numerals, the standard "WHEREAS" preamble convention.
% -----------------------------------------------------------------------------
\NewLdsCounter{Article}{articles}{article}
\NewLdsCounter{Clause}{clauses}{clause}
\NewLdsCounter{Recital}{recitals}{recital}

% Make Clause numbers reset each Article and render as N.M.
\@addtoreset{LdsClause}{LdsArticle}
\renewcommand{\theLdsClause}{\theLdsArticle.\arabic{LdsClause}}
% Recital numbers are roman lowercase and stand alone.
\renewcommand{\theLdsRecital}{(\roman{LdsRecital})}

% Public command forms.
\newcommand{\Article}[1]{%
  \refstepcounter{LdsArticle}%
  \section*{Article \theLdsArticle.\quad #1}%
  \addcontentsline{toc}{section}%
    {Article \theLdsArticle.\texorpdfstring{\quad}{ }#1}%
}
\newcommand{\Clause}[1]{%
  \refstepcounter{LdsClause}%
  \subsection*{\theLdsClause\quad #1}%
  \addcontentsline{toc}{subsection}%
    {\theLdsClause\texorpdfstring{\quad}{ }#1}%
}
\newcommand{\Recital}[1]{%
  \refstepcounter{LdsRecital}%
  \par\noindent\textbf{\theLdsRecital}\quad #1\par
}

% -----------------------------------------------------------------------------
% 2. Parties block and defined-term typography
% -----------------------------------------------------------------------------
% \Parties{Acme, LLC ("Provider")}{Beta Co. ("Customer")}
% renders the standard "between A and B" preamble.
\newcommand{\Parties}[2]{%
  \par\noindent
  This Agreement is made and entered into between\\[2pt]
  \hspace*{2em}\textbf{#1}, and\\[2pt]
  \hspace*{2em}\textbf{#2}.\par
}

% \DefinedTerm{Licensee} -- typographic convention for terms-of-art.
\providecommand{\DefinedTerm}[1]{\textsc{\textcolor{Navy}{#1}}}

% -----------------------------------------------------------------------------
% 3. recitals and definitions environments
% -----------------------------------------------------------------------------
% recitals : a "WHEREAS" preamble with roman-numeral leaders.
\newenvironment{recitals}{%
  \par\medskip\textbf{Recitals.}\par
  \setcounter{LdsRecital}{0}%
  \begin{description}[leftmargin=1.6em,labelwidth=1.4em,labelsep=0.4em,
                      style=nextline]%
}{%
  \end{description}\par
}

% definitions : two-column "term -- meaning" list with consistent typography.
\newenvironment{definitions}{%
  \par\medskip\textbf{Definitions.}\par
  \begin{description}[leftmargin=2em,labelsep=0.6em,style=nextline]
}{%
  \end{description}\par
}
\providecommand{\DefnTerm}[1]{\item[\DefinedTerm{#1}]}

% -----------------------------------------------------------------------------
% 4. Labeled callout blocks (via parent factory)
% -----------------------------------------------------------------------------
\NewLdsLabeledBlock{clausebox}{Clause}{Clause}{Navy}
\NewLdsLabeledBlock{articlebox}{Article}{Article}{Steel}
\NewLdsLabeledBlock{recitalbox}{Recital}{Recital}{Teal}

% -----------------------------------------------------------------------------
% 5. Signature panel
% -----------------------------------------------------------------------------
% \makesignaturepanel{Party A label}{Party B label}
\newcommand{\makesignaturepanel}[2]{%
  \par\bigskip
  \noindent\textbf{Signatures.} The undersigned, intending to be legally
  bound, execute this Agreement as of the dates indicated below.
  \par\medskip
  \noindent
  \LdsSignatureLine{0.45\linewidth}{#1}\hfill
  \LdsSignatureLine{0.45\linewidth}{#2}%
  \par\medskip
  \noindent
  \LdsSignatureLine{0.45\linewidth}{Date}\hfill
  \LdsSignatureLine{0.45\linewidth}{Date}%
}

\endinput
