% =============================================================================
% hr.sty
% =============================================================================
% Role in the hierarchy: CONCRETE FAMILY MODULE.
% Generalizes from: base.sty.
%
% Functional class served:
%   Job descriptions, resumes, applicant records, onboarding materials,
%   training schedules, performance reviews, and other workforce records.
%
% Specialization contributed beyond the parent:
%   * `jobdescription` environment: standard top-of-document JD frame with
%     role / department / reports-to / location fields.
%   * Section macros aligned to the JD convention: \Responsibilities,
%     \Qualifications, \NiceToHaves, \Compensation, \HowToApply.
%   * `applicantrecord` environment + \Stage{Date}{Step}{Notes} for hiring
%     pipeline tracking.
%   * `trainingschedule` table for cohort / module / instructor / dates.
%   * `performancerubric` 5-point ratings table + \Rubric{Criterion}{Rating}.
%   * \PII{...}: PII-redaction macro (italic, gray, bracket-wrapped) for any
%     field that should be redacted in distributed copies. The default looks
%     visible-but-de-emphasised; toggle \LdsRedactPIItrue to fully blank it.
%
% The module sets \DocClass = "Human Resources".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hr}%
  [2026/05/08 v1.0 latex-docs human resources family module]

\RequirePackage{base.sty}
\LdsRegisterModule{hr}{Human Resources}

% -----------------------------------------------------------------------------
% 1. PII-handling macro
% -----------------------------------------------------------------------------
% \PII{candidate@example.com}
% Default behaviour: rendered de-emphasized so the field is still visible but
% obviously sensitive. Set \LdsRedactPIItrue (e.g. for distributed copies)
% to replace the contents with a redaction box.
\newif\ifLdsRedactPII
\LdsRedactPIIfalse
\providecommand{\PII}[1]{%
  \ifLdsRedactPII
    {\color{Meta}\rule[0.2ex]{2.5em}{1ex}}%
  \else
    {\itshape\color{Meta}[#1]}%
  \fi
}

% -----------------------------------------------------------------------------
% 2. Job description
% -----------------------------------------------------------------------------
% \begin{jobdescription}{Role title}{Department}{Reports to}{Location}
%   ...sections...
% \end{jobdescription}
\newenvironment{jobdescription}[4]{%
  \par\noindent
  \begin{tcolorbox}[colback=Soft,colframe=Navy,boxrule=0.5pt,arc=2pt,
                    left=4mm,right=4mm,top=2mm,bottom=2mm]%
    \begin{tabular}{@{}p{0.18\linewidth}p{0.72\linewidth}@{}}
      \textbf{Role:}        & #1\\
      \textbf{Department:}  & #2\\
      \textbf{Reports to:}  & #3\\
      \textbf{Location:}    & #4\\
    \end{tabular}
  \end{tcolorbox}
  \par
}{}

% Section macros
\newcommand{\Responsibilities}{\subsection*{Responsibilities}}
\newcommand{\Qualifications}{\subsection*{Required qualifications}}
\newcommand{\NiceToHaves}{\subsection*{Preferred qualifications}}
\newcommand{\Compensation}{\subsection*{Compensation \& benefits}}
\newcommand{\HowToApply}{\subsection*{How to apply}}

% -----------------------------------------------------------------------------
% 3. Applicant record (hiring pipeline)
% -----------------------------------------------------------------------------
\NewLdsCounter{HiringStage}{hiring stages}{stage}

\newenvironment{applicantrecord}[2]{%
  \par\noindent\textbf{Applicant.} #1\hfill\textbf{Requisition.} #2\par\smallskip
  \begin{longtable}{@{}l>{\raggedright\arraybackslash}p{0.14\linewidth}%
                       >{\raggedright\arraybackslash}p{0.20\linewidth}%
                       >{\raggedright\arraybackslash}p{0.44\linewidth}@{}}
    \toprule
    \textbf{\#} & \textbf{Date} & \textbf{Stage} & \textbf{Notes}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\Stage}[3]{%
  \refstepcounter{LdsHiringStage}%
  \theLdsHiringStage & #1 & #2 & #3\\
}

% -----------------------------------------------------------------------------
% 4. Training schedule
% -----------------------------------------------------------------------------
\newenvironment{trainingschedule}{%
  \par
  \begin{longtable}{@{}>{\raggedright\arraybackslash}p{0.16\linewidth}%
                       >{\raggedright\arraybackslash}p{0.32\linewidth}%
                       >{\raggedright\arraybackslash}p{0.18\linewidth}%
                       >{\raggedright\arraybackslash}p{0.20\linewidth}@{}}
    \toprule
    \textbf{Cohort} & \textbf{Module} & \textbf{Instructor} & \textbf{Dates}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\TrainingRow}[4]{#1 & #2 & #3 & #4\\}

% -----------------------------------------------------------------------------
% 5. Performance rubric
% -----------------------------------------------------------------------------
% Standard five-point scale.
\newcommand{\RubricScore}[1]{%
  \ifcase#1 \textcolor{Brick}{0 -- N/A}%
  \or       \textcolor{Brick}{1 -- Below}%
  \or       \textcolor{Steel}{2 -- Developing}%
  \or       \textcolor{Steel}{3 -- Meets}%
  \or       \textcolor{Teal}{4 -- Exceeds}%
  \or       \textcolor{Teal}{5 -- Outstanding}%
  \else     \textit{(score?)}%
  \fi}

\newenvironment{performancerubric}{%
  \par
  \begin{longtable}{@{}>{\raggedright\arraybackslash}p{0.32\linewidth}%
                       >{\raggedright\arraybackslash}p{0.18\linewidth}%
                       >{\raggedright\arraybackslash}p{0.36\linewidth}@{}}
    \toprule
    \textbf{Criterion} & \textbf{Rating} & \textbf{Evidence / commentary}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\Rubric}[3]{#1 & \RubricScore{#2} & #3\\}

\endinput



