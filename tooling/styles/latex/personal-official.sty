% =============================================================================
% personal-official.sty
% =============================================================================
% Role in the hierarchy: CONCRETE FAMILY MODULE.
% Generalizes from: base.sty.
%
% Functional class served:
%   Identification cards, certificates, diplomas, official personal records,
%   and credentialing artifacts.
%
% Specialization contributed beyond the parent:
%   * `certificate` environment: a centred, decorative title-page-style frame
%     with deeply spaced typography typical of credentialing artifacts.
%   * \Holder, \Issued, \Authority: structured fields for a certificate's
%     "this is awarded to" body.
%   * `idcard` environment: a small, two-column, framed block sized like an
%     ID card; pairs label/value fields via \IDField.
%   * \OfficialSeal{path}: places an optional seal image at the bottom-right
%     of a certificate; gracefully no-ops via \safeincludegraphics if the
%     file is missing.
%   * \signedby{Name}{Title}: a single-signature variant of the parent
%     \LdsSignatureLine helper; certificates rarely use a two-party panel.
%
% Sets \DocClass = "Personal / Official".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-personal-official}%
  [2026/05/08 v1.0 latex-docs personal and official records family module]

\RequirePackage{base.sty}
\LdsRegisterModule{personal-official}{Personal / Official}

% -----------------------------------------------------------------------------
% 1. Certificate page environment
% -----------------------------------------------------------------------------
% Centres a tcolorbox and hands it deliberately generous breathing room.
\newenvironment{certificate}[1]{%
  \thispagestyle{empty}%
  \begin{center}%
    \begin{tcolorbox}[width=0.92\linewidth,colback=Soft,colframe=Navy,
                      boxrule=2pt,arc=4mm,
                      left=8mm,right=8mm,top=10mm,bottom=10mm,
                      enhanced,
                      borderline={0.6pt}{2.5mm}{Teal}]%
      \begin{center}%
        {\Huge\bfseries\color{Navy} #1}\\[6pt]%
        {\large\color{Steel}\textit{is hereby awarded to}}\\[18pt]%
}{%
      \end{center}%
    \end{tcolorbox}%
  \end{center}%
}

% Field macros used inside `certificate`.
\newcommand{\Holder}[1]{%
  {\LARGE\bfseries\color{Navy} #1}\\[8pt]%
  \rule{0.5\linewidth}{0.4pt}\\[14pt]%
}
\newcommand{\Issued}[1]{%
  \par{\large\textit{#1}}\\[10pt]%
}
\newcommand{\Authority}[1]{%
  \par\small\color{Steel} #1\par
}

\newcommand{\OfficialSeal}[1]{%
  \par\hfill\safeincludegraphics[width=2.6cm]{#1}\par
}

\newcommand{\signedby}[2]{%
  \par\bigskip
  \LdsSignatureLine{0.55\linewidth}{#1, #2}\par
}

% -----------------------------------------------------------------------------
% 2. ID card layout
% -----------------------------------------------------------------------------
\newenvironment{idcard}[1]{%
  \par\noindent
  \begin{tcolorbox}[width=0.6\linewidth,colback=Soft,colframe=Navy,
                    boxrule=0.6pt,arc=2pt,
                    title=\textbf{#1},coltitle=white,fonttitle=\bfseries]%
    \begin{tabular}{@{}p{0.36\linewidth}>{\raggedright\arraybackslash}p{0.54\linewidth}@{}}
}{%
    \end{tabular}
  \end{tcolorbox}\par
}
\newcommand{\IDField}[2]{\textbf{#1:} & #2\\}

\endinput



