% =============================================================================
% technical-design-spec.sty
% =============================================================================
% Role in the hierarchy: CONCRETE SUBTYPE.
% Generalizes from: technical -> base.sty.
%
% Functional class served:
%   Design specifications, software design documents (SDDs), architecture
%   decision records (ADRs), and other "what we will build and why" artifacts
%   read primarily by engineers and architects.
%
% Specialization contributed beyond the abstract technical module:
%   * \ADR{Title}{Status} : an ADR header + status badge with the conventional
%     {Proposed, Accepted, Deprecated, Superseded} status set, coloured.
%   * `adr` environment: standard Context / Decision / Consequences sections
%     emitted in one block, relieving authors from re-typing the headings.
%   * `traceability` matrix: requirements -> components / interfaces / tests.
%   * \DesignDecision{label}{decision text}: a labelable inline assertion with
%     a "DD-N" stable id for cross-document references.
%
% Sets \DocClass = "Technical / Design Specification".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{technical-design-spec}%
  [2026/05/08 v1.0 latex-docs technical design specification subtype]

\RequirePackage{technical}
\LdsRegisterModule{technical-design-spec}{Technical / Design Specification}

% -----------------------------------------------------------------------------
% 1. ADR support
% -----------------------------------------------------------------------------
\newcommand{\ADRStatus}[1]{%
  % Coloured pill for ADR status. Falls through to a neutral chip for unknown
  % values so unusual statuses still typeset without warning.
  \def\lds@adr@col{Steel}%
  \def\lds@adr@txt{#1}%
  \edef\lds@adr@cmp{#1}%
  \def\lds@adr@P{Proposed}%
  \def\lds@adr@A{Accepted}%
  \def\lds@adr@D{Deprecated}%
  \def\lds@adr@S{Superseded}%
  \ifx\lds@adr@cmp\lds@adr@P \def\lds@adr@col{Steel}\fi
  \ifx\lds@adr@cmp\lds@adr@A \def\lds@adr@col{Teal}\fi
  \ifx\lds@adr@cmp\lds@adr@D \def\lds@adr@col{Brick}\fi
  \ifx\lds@adr@cmp\lds@adr@S \def\lds@adr@col{Brick}\fi
  \tcbox[on line,colback=\lds@adr@col,colframe=\lds@adr@col,
         coltext=white,boxsep=1pt,left=4pt,right=4pt,top=1pt,bottom=1pt,
         arc=2pt]{\footnotesize\bfseries #1}%
}

\NewLdsCounter{ADR}{ADRs}{ADR}
\newcommand{\ADR}[2]{%
  \refstepcounter{LdsADR}%
  \section*{ADR-\theLdsADR.\quad #1\hfill\ADRStatus{#2}}%
  \addcontentsline{toc}{section}%
    {ADR-\theLdsADR.\texorpdfstring{\quad}{ }#1}%
}

% \begin{adr}{Decision title}{Status}
%   \ADRContext{...}
%   \ADRDecision{...}
%   \ADRConsequences{...}
% \end{adr}
\newenvironment{adr}[2]{%
  \ADR{#1}{#2}%
}{%
  \par\medskip
}
\newcommand{\ADRContext}[1]{\subsubsection*{Context}#1}
\newcommand{\ADRDecision}[1]{\subsubsection*{Decision}#1}
\newcommand{\ADRConsequences}[1]{\subsubsection*{Consequences}#1}

% -----------------------------------------------------------------------------
% 2. Traceability matrix
% -----------------------------------------------------------------------------
\newenvironment{traceability}{%
  \par
  \begin{longtable}{@{}>{\raggedright\arraybackslash}p{0.14\linewidth}%
                       >{\raggedright\arraybackslash}p{0.28\linewidth}%
                       >{\raggedright\arraybackslash}p{0.22\linewidth}%
                       >{\raggedright\arraybackslash}p{0.24\linewidth}@{}}
    \toprule
    \textbf{Req ID} & \textbf{Statement} &
    \textbf{Component(s)} & \textbf{Test(s)}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\Trace}[4]{#1 & #2 & #3 & #4\\}

% -----------------------------------------------------------------------------
% 3. Numbered design decisions
% -----------------------------------------------------------------------------
\NewLdsCounter{DesignDecision}{design decisions}{design decision}

\newcommand{\DesignDecision}[2]{%
  \refstepcounter{LdsDesignDecision}%
  \par\noindent
  \begin{tcolorbox}[colback=Soft,colframe=Navy,boxrule=0.4pt,arc=2pt,
                    left=3mm,right=3mm,top=1.5mm,bottom=1.5mm,
                    title=\textbf{Design Decision DD-\theLdsDesignDecision~--~#1},
                    coltitle=white,fonttitle=\bfseries]%
    #2
  \end{tcolorbox}\par
}

\endinput



