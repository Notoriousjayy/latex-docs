% =============================================================================
% latex-docs-technical-user-manual.sty
% =============================================================================
% Role in the hierarchy: CONCRETE SUBTYPE.
% Generalizes from: latex-docs-technical (abstract intermediate), which
%                   itself generalizes from latex-docs-base.
%
% Functional class served:
%   End-user manuals: task-oriented documentation that guides a non-expert
%   user through accomplishing concrete goals using a system or product.
%
% Specialization contributed beyond the abstract technical module:
%   * `task` and `tutorial` environments: the basic shape of a how-to
%     section, with an opening "What you will do" lead-in box.
%   * GUI semantics: \Menu{File>Open}, \Button{Save}, \Field{Email},
%     \Tab{Settings}, \Window{Preferences} -- consistent typography for
%     every element a user can click, type into, or look at.
%   * `troubleshooting` Q/A environment: paired symptom/resolution rows.
%   * \UserNote, \UserTip -- thin semantic wrappers over the parent's
%     notebox / tipbox tuned for end-user reading level.
%
% Sets \DocClass = "Technical / User Manual".
% =============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{latex-docs-technical-user-manual}%
  [2026/05/08 v1.0 latex-docs technical user manual subtype]

\RequirePackage{latex-docs-technical}
\LdsRegisterModule{technical-user-manual}{Technical / User Manual}

% -----------------------------------------------------------------------------
% 1. Task and tutorial environments
% -----------------------------------------------------------------------------
% \begin{task}{Reset your password}{What you'll do.}
%   ...steps, screenshots, results...
% \end{task}
\newenvironment{task}[2]{%
  \subsection*{Task: #1}%
  \begin{viewbox}\small\textbf{What you will do.} #2\end{viewbox}%
  \par
}{%
  \par\medskip
}

\newenvironment{tutorial}[2]{%
  \section*{Tutorial: #1}%
  \begin{viewbox}\small\textbf{Goal.} #2\end{viewbox}%
  \par
}{%
  \par\medskip
}

% -----------------------------------------------------------------------------
% 2. GUI element semantics
% -----------------------------------------------------------------------------
% \Menu{File > Open}        -> menu paths
% \Button{Save}             -> clickable actions
% \Field{Email}             -> form fields
% \Tab{Settings}            -> tab labels
% \Window{Preferences}      -> window / dialog titles
\providecommand{\Menu}[1]{\textsf{\textbf{#1}}}
\providecommand{\Button}[1]{\textsf{[\,#1\,]}}
\providecommand{\Field}[1]{\textsf{\emph{#1}}}
\providecommand{\Tab}[1]{\textsf{\textbf{#1}}}
\providecommand{\Window}[1]{\textsf{\emph{#1}}}

% -----------------------------------------------------------------------------
% 3. Troubleshooting environment
% -----------------------------------------------------------------------------
\newenvironment{troubleshooting}{%
  \subsection*{Troubleshooting}
  \par
  \begin{longtable}{@{}>{\raggedright\arraybackslash}p{0.40\linewidth}%
                       >{\raggedright\arraybackslash}p{0.50\linewidth}@{}}
    \toprule
    \textbf{Symptom} & \textbf{Resolution}\\
    \midrule
    \endhead
    \bottomrule
    \endfoot
}{%
  \end{longtable}\par
}
\newcommand{\TS}[2]{#1 & #2\\}

% -----------------------------------------------------------------------------
% 4. Reading-level-tuned notes
% -----------------------------------------------------------------------------
% These are deliberately short; they wrap notebox/tipbox so end-user docs
% read consistently regardless of which writer authored a section.
\newenvironment{UserNote}[1][Note]{\begin{notebox}[#1]}{\end{notebox}}
\newenvironment{UserTip}[1][Tip]{\begin{tipbox}[#1]}{\end{tipbox}}

\endinput
