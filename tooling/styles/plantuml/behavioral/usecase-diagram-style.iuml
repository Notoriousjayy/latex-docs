' ======================================================================
'  usecase-diagram-style.iuml
'  Diagram-specific specialization for UML USE CASE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-behavioral
'
'  Use case diagrams capture user-visible system functionality. The
'  distinguishing features are:
'    - actor stick-figures positioned at the boundary of a system
'    - a "system" rectangle enclosing the use cases
'    - <<include>> and <<extend>> dependency arrows
'  Actor + use-case styling is inherited from uml-behavioral.
' ======================================================================

!ifndef USECASE_DIAGRAM_STYLE_INCLUDED
!define USECASE_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-behavioral.iuml

' Use case diagrams almost always read left-to-right
' (actors on the sides, use cases in the middle).
left to right direction

' System boundary helper
!unquoted procedure UC_SYSTEM($name)
rectangle "$name" {
!endprocedure

!unquoted procedure UC_END_SYSTEM()
}
!endprocedure

' <<include>> dependency: base ..> included
!unquoted procedure UC_INCLUDE($base, $included)
$base ..> $included : <<include>>
!endprocedure

' <<extend>> dependency: extension ..> base
!unquoted procedure UC_EXTEND($extension, $base)
$extension ..> $base : <<extend>>
!endprocedure

' Actor generalization
!unquoted procedure UC_ACTOR_GEN($child, $parent)
$child --|> $parent
!endprocedure

!endif



