' ======================================================================
'  activity-diagram-style.iuml
'  Diagram-specific specialization for UML ACTIVITY diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-behavioral
'
'  Activity diagrams describe workflow / control flow. Most visual
'  conventions (start/end nodes, decision diamonds, fork/join bars,
'  swimlane palette, arrow defaults) are inherited from
'  uml-behavioral. This module adds only the activity-specific
'  shorthand for the "new" PlantUML activity syntax.
' ======================================================================

!ifndef ACTIVITY_DIAGRAM_STYLE_INCLUDED
!define ACTIVITY_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-behavioral.iuml

' The PlantUML "new activity" syntax (:action;) renders nicer
' than the legacy syntax. We apply consistent arrow + emphasis here.
skinparam ConditionEndStyle hline

' Helper: a swimlane / partition with a labelled title bar
!unquoted procedure ACT_LANE($title)
|$title|
!endprocedure

' Helper: a labelled action node
!unquoted procedure ACT_DO($label)
:$label;
!endprocedure

' Helper: a decision diamond with an "if" header
!unquoted procedure ACT_IF($cond)
if ($cond) then (yes)
!endprocedure

!unquoted procedure ACT_ELSE()
else (no)
!endprocedure

!unquoted procedure ACT_ENDIF()
endif
!endprocedure

!endif



