' ======================================================================
'  statemachine-diagram-style.iuml
'  Diagram-specific specialization for UML STATE MACHINE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-behavioral
'
'  State machine diagrams describe the lifecycle of a single entity
'  in terms of states and transitions. Most styling (state container
'  shape, start/end markers, transition arrows) is inherited from
'  uml-behavioral; this module adds the entry / exit / do action
'  conventions plus a couple of helpful shorthand macros.
' ======================================================================

!ifndef STATEMACHINE_DIAGRAM_STYLE_INCLUDED
!define STATEMACHINE_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-behavioral.iuml

' Composite states (substates) read more clearly with a slight
' surface contrast.
skinparam state {
  BackgroundColor<<composite>> $theme_surface_2
  BorderColor<<composite>>     $theme_secondary
}

' Entry / exit / do action declared on a state.
' Usage:  STM_ENTRY(Idle, "load configuration")
!unquoted procedure STM_ENTRY($state, $action)
$state : entry / $action
!endprocedure

!unquoted procedure STM_EXIT($state, $action)
$state : exit / $action
!endprocedure

!unquoted procedure STM_DO($state, $action)
$state : do / $action
!endprocedure

' Internal transition (does not exit/re-enter the state).
!unquoted procedure STM_INTERNAL($state, $event, $action)
$state : $event / $action
!endprocedure

!endif



