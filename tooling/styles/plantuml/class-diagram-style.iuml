' ======================================================================
'  class-diagram-style.iuml
'  Diagram-specific specialization for UML CLASS diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'  HIERARCHY: uml-base -> uml-structural -> THIS FILE
'
'  This module owns ONLY conventions that are specific to class
'  diagrams and not shared with object, component, deployment,
'  package, composite-structure, or profile diagrams.
'
'  Almost everything (class container styling, generalization arrows,
'  realization arrows, stereotype shorthand) is already inherited
'  from uml-structural -> uml-base. Keep this file thin on purpose.
' ======================================================================

!ifndef CLASS_DIAGRAM_STYLE_INCLUDED
!define CLASS_DIAGRAM_STYLE_INCLUDED

!include ../uml-structural.iuml

' Class diagrams almost always benefit from explicit visibility icons
' and a hidden empty-method indicator (so abstract intent reads clean).
skinparam classAttributeIconSize 10
skinparam classFontStyle         plain
hide empty members

' Default to top-down for inheritance hierarchies; authors override
' with STRUCT_LAYOUT_LR() when modelling broad horizontal models.
top to bottom direction

' Diagram-type-specific shorthand: declare an abstract class one-liner.
!unquoted procedure CLASS_ABSTRACT($name)
abstract class $name
!endprocedure

!unquoted procedure CLASS_INTERFACE($name)
interface $name
!endprocedure

!unquoted procedure CLASS_ENUM($name)
enum $name
!endprocedure

!endif
