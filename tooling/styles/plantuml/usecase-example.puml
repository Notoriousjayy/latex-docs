' --------------------------------------------------------------
' Diagram   : Online ordering use cases
' Type      : Use Case
' Owns      : User-facing capabilities of the storefront subsystem.
' Author    : framework demo
' Status    : draft
' --------------------------------------------------------------
@startuml ordering-usecases

!include ../styles/behavioral/usecase-diagram-style.iuml

title Online Ordering -- Use Case Overview

actor "Customer"     as C
actor "Returning Customer" as RC
actor "Payment Gateway" as PG <<system>>

UC_ACTOR_GEN(RC, C)

UC_SYSTEM("Storefront")
  usecase "Browse Catalog"  as UC1
  usecase "Place Order"     as UC2
  usecase "Apply Discount"  as UC3
  usecase "Pay for Order"   as UC4
  usecase "Track Shipment"  as UC5
UC_END_SYSTEM()

C  -- UC1
C  -- UC2
RC -- UC5
UC4 -- PG

UC_INCLUDE(UC2, UC4)
UC_EXTEND(UC3, UC2)

UML_NOTE_INFO(N1, UC4, "Pay for Order is a synchronous call\ninto the Payment Gateway system.")

@enduml



