' ======================================================================
'  composite-structure-diagram-style.iuml
'  Specialization for UML COMPOSITE STRUCTURE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Composite structure diagrams visualise the internal arrangement
'  of a classifier: parts, ports, and connectors that link them.
'  The distinguishing visual elements versus class diagrams are:
'    - "parts" rendered as rectangles inside the owning classifier
'    - ports rendered as small squares on the boundary
'    - connectors as plain lines (not associations)
' ======================================================================

!ifndef COMPOSITE_STRUCTURE_DIAGRAM_STYLE_INCLUDED
!define COMPOSITE_STRUCTURE_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-structural.iuml

' "Parts" are typically modelled as nested rectangles in PlantUML.
skinparam rectangle {
  RoundCorner 4
}

' Helper: declare a part inside a classifier
!unquoted procedure CSD_PART($name, $type)
rectangle "$name : $type" as $name
!endprocedure

' Helper: declare a port on a classifier boundary
!unquoted procedure CSD_PORT($name)
() $name
!endprocedure

' Connector between two parts (or between a port and a part)
!unquoted procedure CSD_CONNECTOR($a, $b, $label="")
$a -- $b : $label
!endprocedure

!endif



