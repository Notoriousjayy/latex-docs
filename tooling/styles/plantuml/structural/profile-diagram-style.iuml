' ======================================================================
'  profile-diagram-style.iuml
'  Diagram-specific specialization for UML PROFILE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Profile diagrams define UML profile extensions: stereotypes,
'  tagged values, and constraints that extend the metamodel. Their
'  distinguishing visual is the "extension" arrow (filled triangle,
'  dashed line) from a stereotype to a metaclass.
' ======================================================================

!ifndef PROFILE_DIAGRAM_STYLE_INCLUDED
!define PROFILE_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-structural.iuml

' Profile diagrams visually distinguish stereotypes from regular
' classes. We highlight the «stereotype» border in the accent colour
' so reviewers can scan the diagram and find extensions quickly.
skinparam class {
  BorderColor<<stereotype>> $theme_accent
  BackgroundColor<<stereotype>> $theme_surface
}

skinparam class {
  BorderColor<<metaclass>> $theme_secondary
  BackgroundColor<<metaclass>> $theme_surface_2
}

' Extension arrow:  stereotype  ..|>  metaclass
' Drawn as a dashed generalization to convey "metamodel extension".
!unquoted procedure PROF_EXTENSION($stereo, $metaclass)
$stereo ..|> $metaclass : <<extends>>
!endprocedure

!endif



