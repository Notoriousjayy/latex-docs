' ======================================================================
'  deployment-diagram-style.iuml
'  Diagram-specific specialization for UML DEPLOYMENT diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Deployment diagrams show the mapping of artifacts to nodes
'  (devices and execution environments). Their distinguishing
'  visual is the 3D node shape and explicit artifact stereotypes.
' ======================================================================

!ifndef DEPLOYMENT_DIAGRAM_STYLE_INCLUDED
!define DEPLOYMENT_DIAGRAM_STYLE_INCLUDED

!include ../uml-structural.iuml

' Node depth and artifact emphasis
skinparam node {
  RoundCorner 4
}
skinparam artifact {
  BackgroundColor $theme_surface
  BorderColor     $theme_secondary
  FontColor       $theme_text
}

' Helper: declare a device node (UML <<device>> stereotype)
!unquoted procedure DEPLOY_DEVICE($name, $label)
node "$label" as $name <<device>>
!endprocedure

' Helper: declare an execution environment node
!unquoted procedure DEPLOY_EXECENV($name, $label)
node "$label" as $name <<executionEnvironment>>
!endprocedure

' Helper: declare a deployed artifact
!unquoted procedure DEPLOY_ARTIFACT($name, $label)
artifact "$label" as $name
!endprocedure

' Communication path between two nodes (solid line, no arrowheads)
!unquoted procedure DEPLOY_COMMPATH($a, $b, $label="")
$a -- $b : $label
!endprocedure

!endif



