' ======================================================================
'  component-diagram-style.iuml
'  Diagram-specific specialization for UML COMPONENT diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Component diagrams emphasise provided/required interfaces (the
'  "lollipop" + "socket" notation) and assembly connectors. Most
'  visual rules already come from uml-structural; we only set the
'  component-style hint and provide assembly macros.
' ======================================================================

!ifndef COMPONENT_DIAGRAM_STYLE_INCLUDED
!define COMPONENT_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-structural.iuml

' Use rectangular components with the embedded component icon
' (UML 2.x convention; preferred over the legacy box-with-tabs).
skinparam componentStyle rectangle

' Provided interface (lollipop):  component  -()  iface
!unquoted procedure COMP_PROVIDES($comp, $iface)
$comp -() $iface
!endprocedure

' Required interface (socket):    component  -(0  iface
!unquoted procedure COMP_REQUIRES($comp, $iface)
$comp -(0 $iface
!endprocedure

' Assembly connector between a required and a provided interface:
' (provider) -()- (consumer)
!unquoted procedure COMP_ASSEMBLY($provider, $iface, $consumer)
$provider -( $iface
$iface )- $consumer
!endprocedure

!endif



