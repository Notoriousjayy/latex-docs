' ======================================================================
'  timing-diagram-style.iuml
'  Diagram-specific specialization for UML TIMING diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-interaction
'
'  Timing diagrams visualise state changes of one or more lifelines
'  against a horizontal time axis. PlantUML's "robust" / "concise"
'  lifeline notations are the standard rendering.
'
'  This module adds duration-emphasis defaults and shorthand for
'  the two lifeline kinds.
' ======================================================================

!ifndef TIMING_DIAGRAM_STYLE_INCLUDED
!define TIMING_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-interaction.iuml

' Robust lifeline (used for systems with discrete states).
!unquoted procedure TIM_ROBUST($alias, $label)
robust "$label" as $alias
!endprocedure

' Concise lifeline (used for high-cardinality value channels).
!unquoted procedure TIM_CONCISE($alias, $label)
concise "$label" as $alias
!endprocedure

' Annotate a duration constraint between two timestamps.
!unquoted procedure TIM_DURATION($from, $to, $label)
$from -> $to : $label
!endprocedure

!endif



