' ======================================================================
'  interaction-overview-diagram-style.iuml
'  Specialization for UML INTERACTION OVERVIEW diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-interaction
'
'  Interaction overview diagrams blend activity-diagram control flow
'  with embedded interaction frames. They share lifeline / message
'  conventions with sequence/communication/timing diagrams (hence
'  inheriting from uml-interaction) but compose them inside an
'  activity-style flow graph.
'
'  PlantUML does not have a single dedicated rendering for this UML
'  type; the typical practice is an activity diagram whose action
'  nodes reference named interactions via INTER_REF (inherited).
' ======================================================================

!ifndef INTERACTION_OVERVIEW_DIAGRAM_STYLE_INCLUDED
!define INTERACTION_OVERVIEW_DIAGRAM_STYLE_INCLUDED

!include ../../../plantuml/uml-interaction.iuml

' We deliberately also pull the activity baseline so the overview
' renders with both vocabularies available.
!include ../behavioral/activity-diagram-style.iuml

' Helper: declare a "sd" reference frame as an activity step.
' Usage:  IOV_REF_STEP("sd Login")
!unquoted procedure IOV_REF_STEP($name)
:ref: $name;
!endprocedure

!endif



