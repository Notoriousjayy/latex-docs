' ======================================================================
'  uml-base.iuml
'  Root style module for the UML PlantUML style framework.
' ----------------------------------------------------------------------
'  HIERARCHY POSITION
'      uml-base                <-- THIS FILE (root)
'        |-- uml-structural
'        |-- uml-behavioral
'             |-- uml-interaction
'
'  RESPONSIBILITY
'      Owns ONLY concerns genuinely shared by every UML diagram type.
'      Anything specific to a UML category (structural/behavioral/
'      interaction) or to a single diagram type belongs in a child
'      module, never here.
'
'  WHAT THIS MODULE OWNS
'      - global skinparams (font, padding, shadow, rounding)
'      - typography conventions
'      - the theme color palette (named tokens, not raw hex in users)
'      - default line and arrow conventions
'      - title / caption / legend styling helpers
'      - note styling and reusable note macros
'      - stereotype + tagged-value conventions
'      - generic helper macros (grouping, captions, dividers)
'      - shared documentation comment template
'
'  WHAT THIS MODULE EXPLICITLY DOES NOT OWN
'      - any class/object/component/node-specific styling
'      - any actor/state/activity-specific styling
'      - any lifeline/message/activation-specific styling
'      - any diagram-type-specific layout overrides
'
'  NAMING CONVENTIONS USED HERE AND INHERITED BY ALL DESCENDANTS
'      Theme tokens   : $theme_*           (e.g. $theme_primary)
'      Base macros    : UML_<CONCEPT>      (e.g. UML_NOTE_INFO)
'      Category macros: STRUCT_*, BEHAV_*, INTER_*  (in child modules)
'      Diagram macros : <DIAG>_*           (e.g. CLASS_, SEQ_)
' ======================================================================

!ifndef UML_BASE_INCLUDED
!define UML_BASE_INCLUDED

' ----------------------------------------------------------------------
' 1. THEME PALETTE  --  named tokens, never raw hex in user diagrams
' ----------------------------------------------------------------------
' Tokens are deliberately named by ROLE, not by hue, so future palette
' swaps require editing only this file.
!$theme_primary    = "#1F3B73"   ' navy   - primary structural emphasis
!$theme_secondary  = "#4A6FA5"   ' steel  - secondary emphasis
!$theme_accent     = "#2A8C8C"   ' teal   - behavioral / dynamic emphasis
!$theme_warn       = "#B5471F"   ' brick  - warnings, exceptional flow
!$theme_surface    = "#F7F7F2"   ' paper  - container fill
!$theme_surface_2  = "#ECEEE8"   ' paper2 - nested container fill
!$theme_border     = "#B8B8B0"   ' border - default stroke
!$theme_text       = "#2D2D2D"   ' ink    - body text
!$theme_muted      = "#6E6E6E"   ' muted  - secondary text, captions
!$theme_grid       = "#D8D8D2"   ' grid   - dividers, lifeline ticks

' ----------------------------------------------------------------------
' 2. GLOBAL SKINPARAMS  --  applied to every UML diagram
' ----------------------------------------------------------------------
skinparam backgroundColor      transparent
skinparam shadowing            false
skinparam roundCorner          6
skinparam padding              4
skinparam defaultTextAlignment center
skinparam wrapWidth            220
skinparam maxMessageSize       180

' Typography
skinparam defaultFontName      "Helvetica"
skinparam defaultFontSize      12
skinparam defaultFontColor     $theme_text

skinparam titleFontName        "Helvetica"
skinparam titleFontSize        16
skinparam titleFontColor       $theme_primary
skinparam titleFontStyle       bold

skinparam captionFontName      "Helvetica"
skinparam captionFontSize      10
skinparam captionFontColor     $theme_muted
skinparam captionFontStyle     italic

' Arrow / line defaults (descendants override only the heads/styles
' that are semantically different in their category).
skinparam ArrowColor           $theme_text
skinparam ArrowFontColor       $theme_text
skinparam ArrowFontSize        11
skinparam ArrowThickness       1

' Notes (plain note style; categories override accent variants)
skinparam NoteBackgroundColor  $theme_surface
skinparam NoteBorderColor      $theme_border
skinparam NoteFontColor        $theme_text
skinparam NoteFontSize         11

' Legend
skinparam LegendBackgroundColor $theme_surface
skinparam LegendBorderColor     $theme_border
skinparam LegendFontColor       $theme_text
skinparam LegendFontSize        10

' Stereotype text (consistent across every diagram type)
skinparam StereotypeFontSize       10
skinparam StereotypeFontStyle      italic
skinparam StereotypeFontColor      $theme_muted

' ----------------------------------------------------------------------
' 3. SHARED HELPER MACROS
' ----------------------------------------------------------------------
' Every macro defined here is safe to call from ANY descendant module
' or any user diagram. Category-specific helpers live in child modules.

' --- Note variants (all UML diagrams use notes the same way) ---
!unquoted procedure UML_NOTE_INFO($id, $target, $text)
note right of $target as $id #$theme_surface
  $text
end note
!endprocedure

!unquoted procedure UML_NOTE_WARN($id, $target, $text)
note right of $target as $id #FBE9E0
  <color:$theme_warn><b>!</b></color> $text
end note
!endprocedure

' --- Caption helper: standardised italic muted footer line ---
!unquoted procedure UML_CAPTION($text)
caption $text
!endprocedure

' --- Stereotype helper: keeps guillemets consistent everywhere ---
!unquoted function UML_STEREO($s)
!return "<<" + $s + ">>"
!endfunction

' --- Tagged-value helper: prints {key = value} in muted italic ---
!unquoted function UML_TAG($k, $v)
!return "<color:" + $theme_muted + "><i>{" + $k + " = " + $v + "}</i></color>"
!endfunction

' --- Section divider for long diagrams (renders as a horizontal rule) ---
!unquoted procedure UML_DIVIDER($text)
== $text ==
!endprocedure

' ----------------------------------------------------------------------
' 4. DOCUMENTATION COMMENT TEMPLATE
' ----------------------------------------------------------------------
' Every diagram authored against this framework should begin with a
' header comment of this form so reviewers can locate the spec quickly:
'
'   ' --------------------------------------------------------------
'   ' Diagram   : <name>
'   ' Type      : <UML diagram type, e.g. Class | Sequence | ...>
'   ' Owns      : <which architectural concern this diagram captures>
'   ' Author    : <author / team>
'   ' Status    : draft | review | approved
'   ' --------------------------------------------------------------
'
' A diagram-specific module MAY emit this header automatically via
' a macro, but it is not enforced here.

!endif
' ======================================================================
'  END uml-base.iuml
' ======================================================================
