' ======================================================================
'  uml-behavioral.iuml
'  Category style module for BEHAVIORAL UML diagrams.
' ----------------------------------------------------------------------
'  HIERARCHY POSITION
'      uml-base
'        |-- uml-behavioral          <-- THIS FILE
'              |-- usecase-diagram-style
'              |-- activity-diagram-style
'              |-- statemachine-diagram-style
'              |-- uml-interaction          (further specialization)
'                    |-- sequence-diagram-style
'                    |-- communication-diagram-style
'                    |-- timing-diagram-style
'                    |-- interaction-overview-diagram-style
'
'  RESPONSIBILITY
'      Specializes uml-base for diagrams that describe DYNAMIC BEHAVIOR
'      (control flow, state, events). This is the LCA of every non-
'      structural diagram, and it is the parent of uml-interaction.
'
'  WHAT THIS MODULE OWNS
'      - actor + use-case container baseline
'      - state and activity-node container baseline
'      - decision / merge / fork / join visual conventions
'      - control-flow arrow conventions (emphasis on direction)
'      - event-trigger and guard label conventions
'      - swimlane / partition styling baseline
'      - shared behavioral macros (transition, guarded transition, fork)
'
'  WHAT THIS MODULE DOES NOT OWN
'      - any class/component/node/package styling   (structural)
'      - any lifeline/message/activation styling    (interaction)
'      - any single-diagram-type quirks             (diagram modules)
'
'  WHY uml-interaction extends THIS MODULE (not uml-base)
'      Interaction diagrams (sequence, communication, timing,
'      interaction-overview) are formally a SUBSET of behavioral
'      diagrams in the UML metamodel. Modeling that as inheritance
'      means lifeline-bearing diagrams automatically receive every
'      behavioral convention (control-flow emphasis, event labels,
'      guard syntax, swimlane palette) without duplication.
' ======================================================================

!ifndef UML_BEHAVIORAL_INCLUDED
!define UML_BEHAVIORAL_INCLUDED

!include uml-base.iuml

' ----------------------------------------------------------------------
' 1. ACTOR + USE-CASE BASELINE
' ----------------------------------------------------------------------
' Actors and use cases are conceptually behavioral participants.
' Their visual treatment is shared by usecase, activity (where actors
' may appear as swimlane owners), and interaction diagrams.

skinparam actor {
  BackgroundColor    $theme_surface
  BorderColor        $theme_accent
  FontColor          $theme_text
  StereotypeFontColor $theme_muted
}

skinparam usecase {
  BackgroundColor    $theme_surface
  BorderColor        $theme_accent
  FontColor          $theme_text
  StereotypeFontColor $theme_muted
}

' ----------------------------------------------------------------------
' 2. ACTIVITY + STATE BASELINE
' ----------------------------------------------------------------------
skinparam activity {
  BackgroundColor    $theme_surface
  BorderColor        $theme_accent
  FontColor          $theme_text
  DiamondBackgroundColor $theme_surface_2
  DiamondBorderColor $theme_accent
  DiamondFontColor   $theme_text
  StartColor         $theme_primary
  EndColor           $theme_warn
  BarColor           $theme_primary
  ArrowColor         $theme_text
  ArrowFontColor     $theme_text
}

skinparam state {
  BackgroundColor    $theme_surface
  BorderColor        $theme_accent
  FontColor          $theme_text
  StartColor         $theme_primary
  EndColor           $theme_warn
  ArrowColor         $theme_text
  ArrowFontColor     $theme_text
}

' Swimlane / partition baseline (used by activity + interaction-overview)
skinparam swimlane {
  TitleFontColor     $theme_primary
  BorderColor        $theme_secondary
}

' ----------------------------------------------------------------------
' 3. CONTROL-FLOW EMPHASIS
' ----------------------------------------------------------------------
' Behavioral diagrams emphasise DIRECTION of flow. We deliberately keep
' the inherited skinparam ArrowColor from uml-base, but provide macros
' that capture intent (event, guard, action) so authors do not have to
' remember UML label conventions.

' Plain transition with optional event/action label
!unquoted procedure BEHAV_TRANSITION($from, $to, $label="")
$from --> $to : $label
!endprocedure

' Guarded transition:   from --> to : event [guard] / action
!unquoted procedure BEHAV_GUARDED($from, $to, $event, $guard, $action)
$from --> $to : $event [$guard] / $action
!endprocedure

' Fork (parallel split) and join (parallel merge) helpers
!unquoted procedure BEHAV_FORK($name)
fork
!endprocedure

!unquoted procedure BEHAV_JOIN()
end fork
!endprocedure

' Decision / merge labels (for activity diagrams)
!unquoted function BEHAV_GUARD($g)
!return "[" + $g + "]"
!endfunction

' ----------------------------------------------------------------------
' 4. EVENT + STEREOTYPE SHORTHAND
' ----------------------------------------------------------------------
!unquoted function BEHAV_STEREO_SIGNAL()
!return UML_STEREO("signal")
!endfunction

!unquoted function BEHAV_STEREO_TRIGGER()
!return UML_STEREO("trigger")
!endfunction

!unquoted function BEHAV_STEREO_INVARIANT()
!return UML_STEREO("invariant")
!endfunction

!endif
' ======================================================================
'  END uml-behavioral.iuml
' ======================================================================
