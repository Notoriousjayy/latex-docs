' ======================================================================
'  communication-diagram-style.iuml
'  Diagram-specific specialization for UML COMMUNICATION diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-interaction
'
'  Communication diagrams (formerly "collaboration diagrams") describe
'  the same information as sequence diagrams but emphasise the
'  STRUCTURAL connections between participants rather than temporal
'  ordering. The defining feature is explicit numerical sequence
'  labels (1:, 1.1:, 2:, ...) on every message.
'
'  PlantUML's "object" notation with numbered messages is the closest
'  rendering. We provide a thin macro that enforces the numbering
'  convention so authors do not handcraft labels.
' ======================================================================

!ifndef COMMUNICATION_DIAGRAM_STYLE_INCLUDED
!define COMMUNICATION_DIAGRAM_STYLE_INCLUDED

!include ../uml-interaction.iuml

' Numbered message: emits "<seq>: <label>" on the arrow.
!unquoted procedure COMM_MSG($from, $to, $seq, $label)
$from -> $to : $seq: $label
!endprocedure

' Numbered return.
!unquoted procedure COMM_RET($from, $to, $seq, $label)
$from --> $to : $seq: $label
!endprocedure

!endif
