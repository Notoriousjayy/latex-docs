' ======================================================================
'  uml-structural.iuml
'  Category style module for STRUCTURAL UML diagrams.
' ----------------------------------------------------------------------
'  HIERARCHY POSITION
'      uml-base
'        |-- uml-structural          <-- THIS FILE
'              |-- class-diagram-style
'              |-- object-diagram-style
'              |-- component-diagram-style
'              |-- deployment-diagram-style
'              |-- package-diagram-style
'              |-- composite-structure-diagram-style
'              |-- profile-diagram-style
'
'  RESPONSIBILITY
'      Specializes uml-base for STATIC ARCHITECTURE diagrams. Owns the
'      visual conventions and relationship macros shared by every
'      structural diagram type but not relevant to behavioral diagrams.
'
'  WHAT THIS MODULE OWNS
'      - container styling baseline for classes, objects, components,
'        nodes, and packages (shared visual rhythm)
'      - port + interface (lollipop / socket) defaults
'      - the canonical structural relationship arrow macros:
'            generalization, realization, dependency,
'            association, aggregation, composition, navigability
'      - structural stereotype shorthand (<<interface>>, <<enum>>,
'        <<abstract>>, <<artifact>>, <<device>>)
'      - shared layout hint helpers for static layouts (left-to-right
'        bias, hierarchical orientation)
'
'  WHAT THIS MODULE DOES NOT OWN
'      - any actor/state/activity/lifeline styling  (behavioral)
'      - any message/activation/timing styling      (interaction)
'      - any single-diagram-type quirks             (diagram modules)
' ======================================================================

!ifndef UML_STRUCTURAL_INCLUDED
!define UML_STRUCTURAL_INCLUDED

' Always pull the parent first so descendants can rely on theme tokens.
!include uml-base.iuml

' ----------------------------------------------------------------------
' 1. CONTAINER BASELINE  --  classes, objects, components, nodes, pkgs
' ----------------------------------------------------------------------
' Each diagram-specific module may override these, but the rhythm
' (rounded corners, neutral surface, navy header) is consistent.

skinparam class {
  BackgroundColor   $theme_surface
  BorderColor       $theme_primary
  HeaderBackgroundColor $theme_primary
  FontColor         $theme_text
  AttributeFontColor $theme_text
  AttributeFontSize 11
  StereotypeFontColor $theme_muted
  RoundCorner       6
}

skinparam object {
  BackgroundColor   $theme_surface
  BorderColor       $theme_secondary
  FontColor         $theme_text
  AttributeFontColor $theme_text
  AttributeFontSize 11
  StereotypeFontColor $theme_muted
}

skinparam component {
  BackgroundColor   $theme_surface
  BorderColor       $theme_primary
  FontColor         $theme_text
}

skinparam interface {
  BackgroundColor   $theme_surface
  BorderColor       $theme_secondary
  FontColor         $theme_text
}

skinparam node {
  BackgroundColor   $theme_surface_2
  BorderColor       $theme_primary
  FontColor         $theme_text
}

skinparam package {
  BackgroundColor   $theme_surface_2
  BorderColor       $theme_secondary
  FontColor         $theme_text
  Style             rectangle
}

skinparam rectangle {
  BackgroundColor   $theme_surface
  BorderColor       $theme_border
  FontColor         $theme_text
}

' ----------------------------------------------------------------------
' 2. STRUCTURAL RELATIONSHIP MACROS
' ----------------------------------------------------------------------
' These macros are the canonical way to draw structural relationships.
' Authors should prefer them over raw arrow syntax so that semantic
' intent is recoverable (and so global restyling is a one-line edit).

' Generalization (inheritance):  child  --|>  parent
!unquoted procedure STRUCT_GENERALIZATION($child, $parent)
$child --|> $parent
!endprocedure

' Realization (interface implementation):  class  ..|>  interface
!unquoted procedure STRUCT_REALIZATION($class, $iface)
$class ..|> $iface
!endprocedure

' Dependency (uses):  client  ..>  supplier
!unquoted procedure STRUCT_DEPENDENCY($client, $supplier, $label="")
$client ..> $supplier : $label
!endprocedure

' Association (general "knows about"):  a  --  b
!unquoted procedure STRUCT_ASSOCIATION($a, $b, $label="")
$a -- $b : $label
!endprocedure

' Directed association (navigable from a -> b)
!unquoted procedure STRUCT_NAVIGABLE($a, $b, $label="")
$a --> $b : $label
!endprocedure

' Aggregation (shared whole/part):  whole  o--  part
!unquoted procedure STRUCT_AGGREGATION($whole, $part, $label="")
$whole o-- $part : $label
!endprocedure

' Composition (exclusive whole/part):  whole  *--  part
!unquoted procedure STRUCT_COMPOSITION($whole, $part, $label="")
$whole *-- $part : $label
!endprocedure

' ----------------------------------------------------------------------
' 3. STEREOTYPE SHORTHAND
' ----------------------------------------------------------------------
' Wrappers over UML_STEREO so authors write intent, not punctuation.
!unquoted function STRUCT_STEREO_INTERFACE()
!return UML_STEREO("interface")
!endfunction

!unquoted function STRUCT_STEREO_ABSTRACT()
!return UML_STEREO("abstract")
!endfunction

!unquoted function STRUCT_STEREO_ENUM()
!return UML_STEREO("enumeration")
!endfunction

!unquoted function STRUCT_STEREO_ARTIFACT()
!return UML_STEREO("artifact")
!endfunction

!unquoted function STRUCT_STEREO_DEVICE()
!return UML_STEREO("device")
!endfunction

' ----------------------------------------------------------------------
' 4. LAYOUT HINTS
' ----------------------------------------------------------------------
' Structural diagrams almost always read left-to-right or top-down.
' We do NOT force a direction here (different diagrams need different
' orientations); we provide opt-in macros instead.

!unquoted procedure STRUCT_LAYOUT_LR()
left to right direction
!endprocedure

!unquoted procedure STRUCT_LAYOUT_TB()
top to bottom direction
!endprocedure

!endif
' ======================================================================
'  END uml-structural.iuml
' ======================================================================
