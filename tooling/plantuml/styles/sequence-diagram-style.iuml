' ======================================================================
'  sequence-diagram-style.iuml
'  Diagram-specific specialization for UML SEQUENCE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-interaction
'
'  Sequence diagrams emphasise temporal ordering: lifelines along
'  the X-axis, time flowing top-down, messages between lifelines.
'  Almost everything we need is inherited from uml-interaction;
'  this module enables auto-numbering by default and provides
'  participant-declaration shorthand.
' ======================================================================

!ifndef SEQUENCE_DIAGRAM_STYLE_INCLUDED
!define SEQUENCE_DIAGRAM_STYLE_INCLUDED

!include ../uml-interaction.iuml

' Auto-numbering is on by default for sequence diagrams; authors who
' do not want numbering can call `autonumber stop` after including.
autonumber

' Participant-declaration shorthand:
!unquoted procedure SEQ_ACTOR($alias, $label)
actor "$label" as $alias
!endprocedure

!unquoted procedure SEQ_PARTICIPANT($alias, $label)
participant "$label" as $alias
!endprocedure

!unquoted procedure SEQ_BOUNDARY($alias, $label)
boundary "$label" as $alias
!endprocedure

!unquoted procedure SEQ_CONTROL($alias, $label)
control "$label" as $alias
!endprocedure

!unquoted procedure SEQ_ENTITY($alias, $label)
entity "$label" as $alias
!endprocedure

!unquoted procedure SEQ_DATABASE($alias, $label)
database "$label" as $alias
!endprocedure

!endif
