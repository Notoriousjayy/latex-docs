' ======================================================================
'  package-diagram-style.iuml
'  Diagram-specific specialization for UML PACKAGE diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Package diagrams are usually used to model module-level
'  dependencies and namespace organisation. The distinguishing
'  features are the «import» / «merge» / «access» stereotypes on
'  dependency arrows.
' ======================================================================

!ifndef PACKAGE_DIAGRAM_STYLE_INCLUDED
!define PACKAGE_DIAGRAM_STYLE_INCLUDED

!include ../uml-structural.iuml

' Package diagrams read more clearly with the tabbed package style.
skinparam package {
  Style folder
}

' Stereotyped dependency arrows (import / merge / access)
!unquoted procedure PKG_IMPORT($a, $b)
$a ..> $b : <<import>>
!endprocedure

!unquoted procedure PKG_MERGE($a, $b)
$a ..> $b : <<merge>>
!endprocedure

!unquoted procedure PKG_ACCESS($a, $b)
$a ..> $b : <<access>>
!endprocedure

!endif
