' --------------------------------------------------------------
' Diagram   : Payment domain model
' Type      : Class
' Owns      : Static structure of the payment subsystem.
' Author    : framework demo
' Status    : draft
' --------------------------------------------------------------
@startuml payment-domain

!include structural/class-diagram-style.iuml

title Payment Domain Model

CLASS_INTERFACE(PaymentMethod) {
  +charge(amount: Money): Receipt
  +refund(receipt: Receipt): void
}

CLASS_ABSTRACT(AbstractPayment) {
  #id: UUID
  #createdAt: Instant
  +charge(amount: Money): Receipt
}

class CreditCardPayment {
  -panLast4: String
  -expiry: YearMonth
  +charge(amount: Money): Receipt
}

class WalletPayment {
  -walletId: WalletId
  +charge(amount: Money): Receipt
}

class Receipt {
  +id: UUID
  +amount: Money
  +method: PaymentMethod
  +timestamp: Instant
}

class Money <<value-object>> {
  +amount: BigDecimal
  +currency: Currency
}

' --- Relationships, declared via the framework macros ---
STRUCT_REALIZATION(AbstractPayment, PaymentMethod)
STRUCT_GENERALIZATION(CreditCardPayment, AbstractPayment)
STRUCT_GENERALIZATION(WalletPayment, AbstractPayment)
STRUCT_COMPOSITION(Receipt, Money, "amount")
STRUCT_DEPENDENCY(AbstractPayment, Receipt, "produces")

UML_NOTE_INFO(N1, AbstractPayment, "Subclasses must be idempotent\nfor a given (id, amount).")

@enduml



