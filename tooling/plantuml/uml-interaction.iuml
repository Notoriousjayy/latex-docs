' ======================================================================
'  uml-interaction.iuml
'  Sub-category style module for INTERACTION diagrams.
' ----------------------------------------------------------------------
'  HIERARCHY POSITION
'      uml-base
'        |-- uml-behavioral
'              |-- uml-interaction          <-- THIS FILE
'                    |-- sequence-diagram-style
'                    |-- communication-diagram-style
'                    |-- timing-diagram-style
'                    |-- interaction-overview-diagram-style
'
'  RESPONSIBILITY
'      Specializes uml-behavioral for the four UML diagram types that
'      describe MESSAGE EXCHANGE between participants. By inheriting
'      from uml-behavioral, every convention here is layered on top
'      of the existing control-flow / event / guard conventions.
'
'  WHAT THIS MODULE OWNS
'      - participant / lifeline visual conventions
'      - activation bar styling
'      - message arrow conventions (sync, async, return, lost, found)
'      - interaction frames / combined fragments (alt, opt, loop, par)
'      - ordering / sequence-number conventions
'      - timing / duration emphasis primitives
'
'  WHAT THIS MODULE DOES NOT OWN
'      - generic actor styling          (lives in uml-behavioral)
'      - generic event/guard helpers    (lives in uml-behavioral)
'      - any single-diagram-type quirks (diagram modules)
'
'  WHY THIS MODULE EXISTS BETWEEN BEHAVIORAL AND THE DIAGRAM MODULES
'      Sequence, communication, timing, and interaction-overview
'      diagrams share more with each other than any of them shares
'      with activity or state-machine diagrams. Putting their common
'      lifeline / message / activation conventions on a dedicated
'      layer prevents that vocabulary from polluting uml-behavioral
'      and prevents duplication across the four interaction modules.
' ======================================================================

!ifndef UML_INTERACTION_INCLUDED
!define UML_INTERACTION_INCLUDED

!include uml-behavioral.iuml

' ----------------------------------------------------------------------
' 1. PARTICIPANT + LIFELINE BASELINE
' ----------------------------------------------------------------------
skinparam participant {
  BackgroundColor    $theme_surface
  BorderColor        $theme_primary
  FontColor          $theme_text
  StereotypeFontColor $theme_muted
}

skinparam sequence {
  ArrowColor             $theme_text
  ArrowFontColor         $theme_text
  LifeLineBorderColor    $theme_grid
  LifeLineBackgroundColor $theme_surface_2
  ParticipantBorderColor $theme_primary
  ParticipantBackgroundColor $theme_surface
  ParticipantFontColor   $theme_text
  ActorBorderColor       $theme_accent
  ActorBackgroundColor   $theme_surface
  BoxBorderColor         $theme_secondary
  BoxBackgroundColor     $theme_surface_2
  GroupBorderColor       $theme_secondary
  GroupBackgroundColor   $theme_surface_2
  GroupHeaderFontColor   $theme_primary
  DividerBackgroundColor $theme_surface_2
  DividerBorderColor     $theme_secondary
  DividerFontColor       $theme_primary
  ReferenceBorderColor   $theme_secondary
  ReferenceBackgroundColor $theme_surface_2
  ReferenceHeaderBackgroundColor $theme_secondary
  ReferenceFontColor     $theme_text
}

' ----------------------------------------------------------------------
' 2. MESSAGE ARROW MACROS
' ----------------------------------------------------------------------
' Authors should call these rather than writing raw arrows so that
' synchronous vs asynchronous vs return semantics remain recoverable.

' Synchronous call:    A -> B : op()
!unquoted procedure INTER_SYNC($from, $to, $label)
$from -> $to : $label
!endprocedure

' Asynchronous send:   A ->> B : op()
!unquoted procedure INTER_ASYNC($from, $to, $label)
$from ->> $to : $label
!endprocedure

' Return message:      B --> A : value
!unquoted procedure INTER_RETURN($from, $to, $label)
$from --> $to : $label
!endprocedure

' Lost message (sender, no known receiver)
!unquoted procedure INTER_LOST($from, $label)
$from ->o] : $label
!endprocedure

' Found message (no known sender, receiver known)
!unquoted procedure INTER_FOUND($to, $label)
[o-> $to : $label
!endprocedure

' Self-call:           A -> A : op()
!unquoted procedure INTER_SELF($who, $label)
$who -> $who : $label
!endprocedure

' ----------------------------------------------------------------------
' 3. ACTIVATION HELPERS
' ----------------------------------------------------------------------
!unquoted procedure INTER_ACTIVATE($who)
activate $who
!endprocedure

!unquoted procedure INTER_DEACTIVATE($who)
deactivate $who
!endprocedure

' ----------------------------------------------------------------------
' 4. COMBINED-FRAGMENT MACROS
' ----------------------------------------------------------------------
' These wrap PlantUML's group/alt/opt/loop/par syntax so that authors
' get consistent labels + frame styling across every interaction
' diagram type without memorising the keyword variants.

!unquoted procedure INTER_FRAGMENT_ALT($cond)
alt $cond
!endprocedure

!unquoted procedure INTER_FRAGMENT_ELSE($cond)
else $cond
!endprocedure

!unquoted procedure INTER_FRAGMENT_OPT($cond)
opt $cond
!endprocedure

!unquoted procedure INTER_FRAGMENT_LOOP($bound)
loop $bound
!endprocedure

!unquoted procedure INTER_FRAGMENT_PAR($label)
par $label
!endprocedure

!unquoted procedure INTER_FRAGMENT_END()
end
!endprocedure

' Reference frame to another interaction (sd / ref)
!unquoted procedure INTER_REF($name, $across)
ref over $across : $name
!endprocedure

' ----------------------------------------------------------------------
' 5. ORDERING + TIMING EMPHASIS
' ----------------------------------------------------------------------
' Communication diagrams need explicit sequence numbers; timing diagrams
' need duration emphasis. We provide thin helpers so the conventions
' are consistent across the four interaction-diagram modules.

!unquoted function INTER_SEQNUM($n, $label)
!return $n + ": " + $label
!endfunction

!unquoted function INTER_DURATION($d)
!return "<color:" + $theme_muted + "><i>{t = " + $d + "}</i></color>"
!endfunction

!endif
' ======================================================================
'  END uml-interaction.iuml
' ======================================================================



