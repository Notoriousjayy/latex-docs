' --------------------------------------------------------------
' Diagram   : Order fulfilment workflow
' Type      : Activity
' Owns      : Operational flow from order receipt to dispatch.
' Author    : framework demo
' Status    : draft
' --------------------------------------------------------------
@startuml order-fulfilment

!include behavioral/activity-diagram-style.iuml

title Order Fulfilment Workflow

start
ACT_LANE(Storefront)
ACT_DO(Receive order)
ACT_DO(Validate cart)

ACT_LANE(Warehouse)
ACT_IF(stock available?)
  ACT_DO(Pick items)
  ACT_DO(Pack shipment)
ACT_ELSE()
  ACT_DO(Notify customer of backorder)
  stop
ACT_ENDIF()

ACT_LANE(Logistics)
ACT_DO(Hand to carrier)
ACT_DO(Track until delivery)
stop

@enduml



