' ======================================================================
'  object-diagram-style.iuml
'  Diagram-specific specialization for UML OBJECT diagrams.
' ----------------------------------------------------------------------
'  PARENT: uml-structural
'
'  Object diagrams are instance snapshots. Their distinguishing
'  features versus class diagrams are:
'    - underlined "name : Type" headers
'    - slot values (attribute = value) instead of attribute signatures
'    - usually no methods displayed
'  Everything else (relationship arrows, stereotypes, container shape)
'  is inherited from uml-structural unchanged.
' ======================================================================

!ifndef OBJECT_DIAGRAM_STYLE_INCLUDED
!define OBJECT_DIAGRAM_STYLE_INCLUDED

!include ../uml-structural.iuml

hide methods
hide circle

' Object header convenience: declares an instance with the standard
' "name : Type" PlantUML object syntax.
!unquoted procedure OBJ_INSTANCE($name, $type)
object "$name : $type" as $name
!endprocedure

!endif



